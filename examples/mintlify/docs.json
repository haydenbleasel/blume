{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Blume Starter Kit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "appearance": {
    "default": "light",
    "strict": true
  },
  "variables": {
    "product-name": "Blume Garden"
  },
  "banner": {
    "content": "Version **2.0** is live. Read the [quickstart](/quickstart).",
    "dismissible": true,
    "type": "info"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#F8FAFC",
      "dark": "#06110B"
    }
  },
  "api": {
    "mdx": {
      "server": "https://api.example.com",
      "auth": {
        "method": "key",
        "name": "x-api-key"
      }
    },
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "javascript"],
      "prefill": true
    }
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "Inter",
    "body": {
      "family": "Inter",
      "weight": 400
    },
    "heading": {
      "family": "Inter",
      "weight": 650
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "search": {
    "prompt": "Search the garden..."
  },
  "seo": {
    "metatags": {
      "og:site_name": "Blume Starter Kit",
      "theme-color": "#16A34A",
      "twitter:site": "@blume"
    }
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    },
    "eyebrows": "breadcrumbs",
    "latex": true
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart", "components", "changelog"]
      },
      {
        "group": "Layout Modes",
        "pages": [
          "modes/default",
          "modes/wide",
          "modes/custom",
          "modes/frame",
          "modes/center"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://blume.dev/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/haydenbleasel/blume",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:hi@blume.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/haydenbleasel/blume"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "links": [
      {
        "header": "Resources",
        "items": [
          {
            "label": "Quickstart",
            "href": "/quickstart"
          },
          {
            "label": "GitHub",
            "href": "https://github.com/haydenbleasel/blume"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "Support",
            "href": "mailto:hi@blume.dev"
          }
        ]
      }
    ],
    "socials": {
      "x": "https://x.com/blume",
      "github": "https://github.com/haydenbleasel/blume",
      "linkedin": "https://linkedin.com/company/blume"
    }
  }
}
