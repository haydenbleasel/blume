---
import Icon from "../Icon.astro";

const { icon, iconType, title } = Astro.props;
---

<section
  class="not-prose my-6 rounded-blume border border-border bg-background p-4"
  data-blume-view-icon={icon}
  data-blume-view-panel
  data-blume-view-title={title}
>
  {
    title && (
      <p class="m-0 mb-3 flex items-center gap-2 font-semibold text-foreground">
        {icon && <Icon iconType={iconType} name={icon} size={16} />}
        {title}
      </p>
    )
  }
  <div class="[&>:first-child]:mt-0 [&>:last-child]:mb-0">
    <slot />
  </div>
</section>
