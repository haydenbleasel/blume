---
import Icon from "../Icon.astro";

interface Props {
  title: string;
  href?: string;
  icon?: string;
}

const { title, href, icon } = Astro.props;
const Tag = href ? "a" : "div";
const external = href?.startsWith("http");
---

<Tag
  class="not-prose block rounded-blume border border-border bg-background p-5 text-inherit transition-colors hover:[&[href]]:border-accent"
  href={href}
  rel={external ? "noreferrer" : undefined}
  target={external ? "_blank" : undefined}
>
  {
    icon && (
      <div class="mb-2.5 text-accent">
        <Icon name={icon} size={20} />
      </div>
    )
  }
  <p class="mb-1.5 flex items-center gap-1.5 font-semibold">
    {title}
    {href && <Icon class="text-muted-foreground" name="arrow-right" size={14} />}
  </p>
  <div class="text-muted-foreground text-sm [&>:first-child]:mt-0 [&>:last-child]:mb-0">
    <slot />
  </div>
</Tag>
