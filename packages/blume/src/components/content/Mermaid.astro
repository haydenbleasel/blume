---
interface Props {
  actions?: boolean | string;
  code: string;
  placement?: "top-left" | "top-right" | "bottom-left" | "bottom-right";
}

const { actions, code, placement = "bottom-right" } = Astro.props;
const actionsValue =
  actions === undefined || actions === null ? "auto" : String(actions);
---

<blume-mermaid
  class="not-prose my-6 block overflow-hidden rounded-blume border border-border bg-background"
  data-actions={actionsValue}
  data-placement={placement}
>
  <div class="relative">
    <div
      class="min-h-32 overflow-hidden bg-muted/20 p-4"
      data-blume-mermaid-viewport
    >
      <pre class="hidden" data-blume-mermaid-source>{code}</pre>
      <div
        class="origin-center transition-transform duration-150 [&_svg]:mx-auto [&_svg]:h-auto [&_svg]:max-w-full"
        data-blume-mermaid-output
      >
      </div>
    </div>
    <div
      class:list={[
        "absolute z-10 flex items-center gap-1 rounded-blume border border-border bg-background/95 p-1 shadow-sm backdrop-blur",
        placement.includes("top") ? "top-2" : "bottom-2",
        placement.includes("left") ? "left-2" : "right-2",
      ]}
      data-blume-mermaid-toolbar
      hidden
    >
      <button
        aria-label="Zoom out"
        class="grid size-7 place-items-center rounded text-muted-foreground text-sm hover:bg-muted hover:text-foreground"
        data-blume-mermaid-control="zoom-out"
        type="button"
      >
        -
      </button>
      <button
        aria-label="Zoom in"
        class="grid size-7 place-items-center rounded text-muted-foreground text-sm hover:bg-muted hover:text-foreground"
        data-blume-mermaid-control="zoom-in"
        type="button"
      >
        +
      </button>
      <button
        aria-label="Pan left"
        class="grid size-7 place-items-center rounded text-muted-foreground text-sm hover:bg-muted hover:text-foreground"
        data-blume-mermaid-control="pan-left"
        type="button"
      >
        &larr;
      </button>
      <button
        aria-label="Pan right"
        class="grid size-7 place-items-center rounded text-muted-foreground text-sm hover:bg-muted hover:text-foreground"
        data-blume-mermaid-control="pan-right"
        type="button"
      >
        &rarr;
      </button>
      <button
        aria-label="Reset view"
        class="grid size-7 place-items-center rounded text-muted-foreground text-sm hover:bg-muted hover:text-foreground"
        data-blume-mermaid-control="reset"
        type="button"
      >
        0
      </button>
    </div>
  </div>
</blume-mermaid>

<script>
  type MermaidApi = typeof import("mermaid").default;

  let initialized = false;
  let mermaidPromise: Promise<MermaidApi> | null = null;
  let renderId = 0;

  const clamp = (value: number, min: number, max: number) =>
    Math.min(max, Math.max(min, value));

  const loadMermaid = () => {
    mermaidPromise ??= import("mermaid").then((module) => module.default);
    return mermaidPromise;
  };

  class BlumeMermaid extends HTMLElement {
    #scale = 1;
    #x = 0;

    connectedCallback() {
      void this.render();
    }

    async render() {
      if (this.dataset.rendered === "true") {
        return;
      }
      this.dataset.rendered = "true";

      const mermaid = await loadMermaid();
      if (!initialized) {
        mermaid.initialize({
          securityLevel: "strict",
          startOnLoad: false,
          theme: "default",
        });
        initialized = true;
      }

      const source = this.querySelector<HTMLElement>(
        "[data-blume-mermaid-source]"
      );
      const output = this.querySelector<HTMLElement>(
        "[data-blume-mermaid-output]"
      );
      const toolbar = this.querySelector<HTMLElement>(
        "[data-blume-mermaid-toolbar]"
      );
      if (!source || !output) {
        return;
      }

      const code = source.textContent ?? "";
      try {
        const id = `blume-mermaid-${++renderId}`;
        const { svg } = await mermaid.render(id, code);
        output.innerHTML = svg;
      } catch {
        output.innerHTML = "";
        const pre = document.createElement("pre");
        pre.className = "overflow-x-auto rounded-blume bg-muted p-4 text-sm";
        pre.textContent = code;
        output.append(pre);
      }

      this.configureControls(output, toolbar);
    }

    configureControls(output: HTMLElement, toolbar: HTMLElement | null) {
      if (!toolbar) {
        return;
      }

      const actions = this.dataset.actions ?? "auto";
      const showControls =
        actions === "true" ||
        (actions === "auto" && output.getBoundingClientRect().height > 120);
      toolbar.hidden = !showControls;
      if (!showControls) {
        return;
      }

      const update = () => {
        output.style.transform = `translateX(${this.#x}px) scale(${
          this.#scale
        })`;
      };

      toolbar.addEventListener("click", (event) => {
        const target = event.target as HTMLElement | null;
        const control = target?.closest<HTMLElement>(
          "[data-blume-mermaid-control]"
        )?.dataset.blumeMermaidControl;
        if (!control) {
          return;
        }

        if (control === "zoom-in") {
          this.#scale = clamp(this.#scale + 0.2, 0.5, 3);
        } else if (control === "zoom-out") {
          this.#scale = clamp(this.#scale - 0.2, 0.5, 3);
        } else if (control === "pan-left") {
          this.#x -= 32;
        } else if (control === "pan-right") {
          this.#x += 32;
        } else if (control === "reset") {
          this.#scale = 1;
          this.#x = 0;
        }
        update();
      });
    }
  }

  if (!customElements.get("blume-mermaid")) {
    customElements.define("blume-mermaid", BlumeMermaid);
  }
</script>
