---
import Icon from "../Icon.astro";

interface Props {
  class?: string;
  icon?: string;
  iconType?: string;
  id?: string;
  style?: string;
  title: string;
}

const { class: className, icon, iconType, id, style, title } = Astro.props;
const slugify = (value: string): string =>
  value
    .toLowerCase()
    .trim()
    .replaceAll(/[^\w\s-]/gu, "")
    .replaceAll(/[\s_]+/gu, "-")
    .replaceAll(/-+/gu, "-")
    .replaceAll(/^-|-$/gu, "");
const tabId = id ?? slugify(title);
---

<div
  class:list={[
    "px-4 py-3 [&:has(>pre)]:p-0 [&>:first-child]:mt-0! [&>:last-child]:mb-0!",
    className,
  ]}
  data-blume-tab-panel
  style={style}
  data-icon={icon}
  data-tab-id={tabId}
  data-title={title}
  id={id}
  role="tabpanel"
>
  <slot />
  {
    icon && (
      <template data-blume-tab-icon>
        <Icon class="shrink-0" iconType={iconType} name={icon} size={14} />
      </template>
    )
  }
</div>
