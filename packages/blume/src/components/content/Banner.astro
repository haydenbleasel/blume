---
import Icon from "../Icon.astro";

type BannerType = "info" | "warning" | "critical";
type BannerColor = string | { dark?: string; light?: string };

interface Props {
  color?: BannerColor;
  dismissible?: boolean | string;
  id?: string;
  title?: string;
  type?: BannerType;
}

const {
  color,
  dismissible = false,
  id,
  title,
  type = "info",
} = Astro.props;

const isDismissible = dismissible === true || dismissible === "true";
const colorLight = typeof color === "string" ? color : color?.light ?? color?.dark;
const colorDark = typeof color === "string" ? color : color?.dark ?? color?.light;
const hasCustomColor = Boolean(colorLight || colorDark);
const bannerStyle = hasCustomColor
  ? `--blume-content-banner-bg-light:${colorLight};--blume-content-banner-bg-dark:${colorDark};`
  : undefined;
const toneClass = hasCustomColor
  ? "bg-[var(--blume-content-banner-bg-light)] text-white dark:bg-[var(--blume-content-banner-bg-dark)]"
  : type === "critical"
    ? "bg-red-600 text-white"
    : type === "warning"
      ? "bg-amber-500 text-white"
      : "bg-accent text-accent-foreground";
const bannerKey = `blume-content-banner:${id ?? title ?? type}:${JSON.stringify(color ?? null)}`;
---

<blume-content-banner
  class:list={[
    "not-prose relative my-5 flex min-h-10 items-center justify-center gap-3 rounded-blume px-4 py-2 text-center text-sm",
    toneClass,
  ]}
  data-blume-banner-key={bannerKey}
  data-dismissible={isDismissible ? "true" : undefined}
  role={type === "critical" ? "alert" : "status"}
  style={bannerStyle}
>
  <div
    class="max-w-5xl [&_a]:font-medium [&_a]:underline [&_a]:decoration-current/50 [&_a]:underline-offset-4 [&_code]:rounded [&_code]:bg-white/15 [&_code]:px-1 [&_code]:py-0.5 [&_p]:m-0"
  >
    {
      title && (
        <strong class="mr-1 inline font-semibold text-current">{title}</strong>
      )
    }
    <slot />
  </div>
  {
    isDismissible && (
      <button
        aria-label="Dismiss banner"
        class="absolute right-2 inline-flex size-7 cursor-pointer items-center justify-center rounded-full text-current/80 transition hover:bg-white/15 hover:text-current"
        data-blume-content-banner-dismiss
        type="button"
      >
        <Icon name="x" size={16} />
      </button>
    )
  }
</blume-content-banner>

<script>
  class BlumeContentBanner extends HTMLElement {
    connectedCallback() {
      if (this.dataset.dismissible !== "true") {
        return;
      }

      const key = this.dataset.blumeBannerKey ?? "";
      try {
        if (localStorage.getItem("blume-content-banner-dismissed") === key) {
          this.hidden = true;
          return;
        }
      } catch {
        // Ignore storage access failures.
      }

      this.querySelector("[data-blume-content-banner-dismiss]")?.addEventListener(
        "click",
        () => {
          this.hidden = true;
          try {
            localStorage.setItem("blume-content-banner-dismissed", key);
          } catch {
            // Ignore storage access failures.
          }
        }
      );
    }
  }

  if (!customElements.get("blume-content-banner")) {
    customElements.define("blume-content-banner", BlumeContentBanner);
  }
</script>
