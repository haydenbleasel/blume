---
import type {
  DirectoryListing,
  DirectoryListingItem,
} from "./nav-utils.ts";
import Icon from "../Icon.astro";
import Self from "./DirectoryListing.astro";

interface Props {
  listing?: DirectoryListing;
  items?: DirectoryListingItem[];
  mode?: DirectoryListing["mode"];
  nested?: boolean;
}

const { listing, items = listing?.items ?? [], mode = listing?.mode ?? "card", nested = false } = Astro.props;

const badgeClass =
  "shrink-0 rounded-full bg-muted px-1.5 py-0.5 font-medium text-[0.65rem] text-muted-foreground leading-none";
const itemLabel = (item: DirectoryListingItem): string =>
  item.kind === "group" ? `${item.label} section` : item.label;
---

{
  items.length > 0 && (
    <section
      aria-label={listing ? `${listing.label} directory` : undefined}
      class={nested ? "mt-3" : "not-prose mt-10"}
      data-blume-directory-listing={listing?.mode}
    >
      {!nested && (
        <h2 class="mb-4 font-semibold text-foreground text-xl tracking-normal">
          Explore {listing?.label}
        </h2>
      )}
      {mode === "card" ? (
        <div
          class={
            nested
              ? "grid gap-2"
              : "grid gap-3 sm:grid-cols-2"
          }
        >
          {items.map((item) => {
            const bodyIsLink = Boolean(item.route && item.children.length === 0);
            const Body = bodyIsLink ? "a" : "div";
            return (
              <Body
                aria-label={itemLabel(item)}
                class="group block rounded-blume border border-border bg-background p-4 text-foreground no-underline transition-colors hover:border-accent hover:no-underline"
                href={bodyIsLink ? item.route : undefined}
              >
                <span class="flex min-w-0 items-start gap-2">
                  {item.icon && (
                    <Icon
                      class="mt-0.5 shrink-0 text-muted-foreground"
                      name={item.icon}
                      size={16}
                    />
                  )}
                  <span class="min-w-0 flex-1">
                    <span class="flex min-w-0 items-center gap-2">
                      {item.route && !bodyIsLink ? (
                        <a
                          class="truncate font-medium text-foreground no-underline hover:text-accent hover:no-underline"
                          href={item.route}
                        >
                          {item.label}
                        </a>
                      ) : (
                        <span class="truncate font-medium">{item.label}</span>
                      )}
                      {item.badge && <span class={badgeClass}>{item.badge}</span>}
                    </span>
                    {item.description && (
                      <span class="mt-1 line-clamp-2 block text-muted-foreground text-sm leading-6">
                        {item.description}
                      </span>
                    )}
                  </span>
                  {item.route && (
                    <Icon
                      class="mt-0.5 shrink-0 text-muted-foreground transition-colors group-hover:text-accent"
                      name="arrow-right"
                      size={15}
                    />
                  )}
                </span>
                {item.children.length > 0 && (
                  <Self items={item.children} mode={mode} nested />
                )}
              </Body>
            );
          })}
        </div>
      ) : (
        <div class={nested ? "space-y-2" : "space-y-3"}>
          {items.map((item) =>
            item.children.length > 0 ? (
              <details class="group rounded-blume border border-border bg-background" open={nested}>
                <summary class="flex cursor-pointer list-none items-center gap-2 px-4 py-3 font-medium text-foreground text-sm transition-colors hover:bg-muted [&::-webkit-details-marker]:hidden">
                  {item.icon && (
                    <Icon
                      class="shrink-0 text-muted-foreground"
                      name={item.icon}
                      size={16}
                    />
                  )}
                  {item.route ? (
                    <a
                      class="min-w-0 flex-1 truncate text-foreground no-underline hover:text-accent hover:no-underline"
                      href={item.route}
                    >
                      {item.label}
                    </a>
                  ) : (
                    <span class="min-w-0 flex-1 truncate">{item.label}</span>
                  )}
                  {item.badge && <span class={badgeClass}>{item.badge}</span>}
                  <Icon
                    class="shrink-0 text-muted-foreground transition-transform group-open:rotate-180"
                    name="chevron-down"
                    size={15}
                  />
                </summary>
                <div class="border-border border-t p-3">
                  <Self items={item.children} mode={mode} nested />
                </div>
              </details>
            ) : item.route ? (
              <a
                class="flex min-w-0 items-start gap-2 rounded-blume border border-border bg-background px-4 py-3 text-foreground no-underline transition-colors hover:border-accent hover:no-underline"
                href={item.route}
              >
                {item.icon && (
                  <Icon
                    class="mt-0.5 shrink-0 text-muted-foreground"
                    name={item.icon}
                    size={16}
                  />
                )}
                <span class="min-w-0 flex-1">
                  <span class="flex min-w-0 items-center gap-2">
                    <span class="truncate font-medium">{item.label}</span>
                    {item.badge && <span class={badgeClass}>{item.badge}</span>}
                  </span>
                  {item.description && (
                    <span class="mt-1 line-clamp-2 block text-muted-foreground text-sm leading-6">
                      {item.description}
                    </span>
                  )}
                </span>
                <Icon class="mt-0.5 shrink-0 text-muted-foreground" name="arrow-right" size={15} />
              </a>
            ) : (
              <div class="rounded-blume border border-border bg-background px-4 py-3">
                <span class="font-medium text-foreground">{item.label}</span>
              </div>
            )
          )}
        </div>
      )}
    </section>
  )
}
