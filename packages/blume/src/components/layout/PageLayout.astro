---
// A full-width page layout for landing pages, marketing pages, dashboards — any
// page that wants Blume's chrome (document shell, header, theme, fonts) without
// the docs sidebar + prose + TOC grid that RootLayout hard-codes. It renders the
// `<head>`, theme/banner pre-paint scripts, banner, and header, then a single
// full-width `<slot />` for the body (plus an optional `footer` slot rendered
// after `<main>`). Import it into a custom page and pull props from `blume:data`:
//
//   import PageLayout from "blume/components/layout/PageLayout.astro";
//   import data from "blume:data";
//   ---
//   <PageLayout site={{ title: data.config.title }} logo={data.config.logo}
//     navigation={data.navigation} themeMode={data.config.theme.mode}
//     fontCssVars={data.fontCssVars} favicon={data.config.favicon}
//     searchEnabled={data.config.search.enabled} page={{ title: "Home" }}>
//     <!-- your full-width content -->
//   </PageLayout>
import type {
  BlumeBanner,
  BlumeClientData,
  BlumeDataConfig,
  BlumeFavicon,
  BlumeLogo,
} from "../../core/data.ts";
import { EN_UI } from "../../core/i18n-ui.ts";
import type { UIStrings } from "../../core/i18n-ui.ts";
import type { LocaleSwitchOption, Navigation } from "../../core/types.ts";
import {
  OG_IMAGE_HEIGHT,
  OG_IMAGE_TYPE,
  OG_IMAGE_WIDTH,
} from "../../og/dimensions.ts";
import { normalizeXHandle } from "../../seo/x-handle.ts";
import { withBase } from "../islands/base-path.ts";
import "blume:theme";
import Analytics from "./Analytics.astro";
import Banner from "./Banner.astro";
import Favicon from "./Favicon.astro";
import Fonts from "./Fonts.astro";
import { BANNER_INIT_SCRIPT, THEME_INIT_SCRIPT } from "./head-scripts.ts";
import Header from "./Header.astro";
import { activeTabForRoute } from "./nav-utils.ts";

interface Props {
  site: { title: string; description?: string };
  logo?: BlumeLogo | null;
  favicon?: BlumeFavicon | null;
  appleIcon?: BlumeFavicon | null;
  banner?: BlumeBanner | null;
  analytics?: BlumeDataConfig["analytics"];
  navigation: Navigation;
  /**
   * Title/description/route for `<title>`, `og:*`, and the header active link.
   * Unlike RootLayout, `title` is used verbatim (no `- siteTitle` suffix), since
   * marketing pages usually set their own complete document title.
   */
  page?: { title?: string; description?: string; route?: string };
  themeMode: "system" | "light" | "dark";
  fontCssVars?: string[];
  searchEnabled: boolean;
  /**
   * Opt this page out of the header's Ask AI trigger. Defaults to whether Ask
   * AI is configured, so a custom page gets the same trigger the docs pages have
   * without wiring anything up.
   */
  askEnabled?: boolean;
  /**
   * Absolute site URL (`data.config.site`). When set, `canonical` and the
   * generated `og:image` for this route are derived from it automatically;
   * `canonical`/`ogImage` below still override.
   */
  siteUrl?: string | null;
  /** Whether OG image generation is on (`data.config.og.enabled`). */
  ogEnabled?: boolean;
  /** SEO overrides; a marketing page often sets its own canonical/og image. */
  ogImage?: string | null;
  canonical?: string | null;
  /**
   * X (Twitter) attribution (`data.config.x`): the site's account and an author
   * handle, emitted as `twitter:site`/`twitter:creator`.
   */
  x?: { creator?: string; handle?: string };
  noindex?: boolean;
  /** Active locale + direction for `<html lang>`/`<html dir>`. */
  locale?: string;
  dir?: "ltr" | "rtl";
  /** Resolved UI dictionary; English baseline when omitted. */
  ui?: UIStrings;
  /** Language-switcher entries for the header. */
  localeSwitch?: LocaleSwitchOption[];
  /**
   * Snapshot for React island hooks (`blume/hooks`). Pass it when a custom page
   * hosts islands that read `useBlume()`/`usePage()`:
   * `clientData={{ config: data.config, navigation: data.navigation, page: { route: "/", title } }}`.
   */
  clientData?: BlumeClientData | null;
}

const {
  site,
  logo,
  favicon,
  appleIcon,
  banner,
  analytics,
  navigation,
  page,
  themeMode,
  fontCssVars,
  searchEnabled,
  askEnabled,
  siteUrl,
  ogEnabled,
  ogImage,
  canonical,
  x,
  noindex,
  locale = "en",
  dir = "ltr",
  ui,
  localeSwitch,
  clientData,
} = Astro.props;

const clientDataJson = clientData
  ? JSON.stringify(clientData).replaceAll("<", "\\u003c")
  : null;

const strings = ui ?? EN_UI;
// Merge over the English defaults so a label missing from a translation (or
// from a not-yet-regenerated snapshot) still renders instead of coming out
// blank — the PageActions pattern.
const navStrings = { ...EN_UI.nav, ...strings.nav };
// Filter search to the active language only when the site is multi-locale.
const searchLocale =
  localeSwitch && localeSwitch.length > 1 ? locale : undefined;
const pageTitle = page?.title ?? site.title;
const description = page?.description ?? site.description;
const route = page?.route ?? "/";
const activeTab = activeTabForRoute(navigation.tabs, route);

// Derive canonical + og:image from the site URL the same way the catch-all does
// for content pages, so a custom page gets both for free. The matching OG card
// (`/og/<slug>.png`, `index` for the home) is generated for static custom pages
// when `og.enabled`. Explicit props still win.
const ogSlug = route === "/" ? "index" : route.slice(1);
// Absolute URLs carry the deployment base too (`site + base + route`), since the
// page is served under it. `withBase` handles a root base as a no-op.
const basedRoute = withBase(route);
// The schema accepts a trailing-slash site URL (`https://docs.example.com/`);
// strip it before joining with the root-relative route so canonical/og URLs
// don't come out double-slashed — the catch-all strips it the same way.
const siteBase = siteUrl ? siteUrl.replace(/\/$/u, "") : null;
const resolvedCanonical =
  canonical ??
  (siteBase ? `${siteBase}${basedRoute === "/" ? "" : basedRoute}` : null);
// An explicit `ogImage` wins. A root-relative path (e.g. an image dropped in
// `public/`) is resolved against the site URL so crawlers get an absolute
// `og:image`; an already-absolute URL passes through untouched. Otherwise fall
// back to the generated OG card for this route.
const absolutizeOgImage = (value: string): string =>
  value.startsWith("/") && siteBase ? `${siteBase}${withBase(value)}` : value;
const resolvedOgImage = ogImage
  ? absolutizeOgImage(ogImage)
  : ogEnabled && siteBase
    ? `${siteBase}${withBase(`/og/${ogSlug}.png`)}`
    : null;
// Only the generated card has a known size and format, so its dimensions are
// declared for crawlers; a user-supplied `ogImage` could be any image.
const ogGenerated = !ogImage && Boolean(resolvedOgImage);
// A page with no image still gets a card on X — the compact `summary` variant
// — rather than rendering as a bare link.
const twitterCard = resolvedOgImage ? "summary_large_image" : "summary";
// A custom page passes these in by hand, so normalize rather than trust the `@`.
const xSite = normalizeXHandle(x?.handle);
const xCreator = normalizeXHandle(x?.creator);

const bannerKey = banner?.dismissible ? banner.key : null;
---

<!doctype html>
<html dir={dir} lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <Favicon appleIcon={appleIcon} favicon={favicon} />
    <Fonts cssVars={fontCssVars ?? []} />
    {resolvedCanonical && <link href={resolvedCanonical} rel="canonical" />}
    {noindex && <meta content="noindex" name="robots" />}
    {description && <meta content={description} name="description" />}
    <meta content="website" property="og:type" />
    <meta content={site.title} property="og:site_name" />
    <meta content={pageTitle} property="og:title" />
    {description && <meta content={description} property="og:description" />}
    {resolvedCanonical && <meta content={resolvedCanonical} property="og:url" />}
    {
      resolvedOgImage && (
        <>
          <meta content={resolvedOgImage} property="og:image" />
          {ogGenerated && (
            <>
              <meta content={OG_IMAGE_TYPE} property="og:image:type" />
              <meta content={String(OG_IMAGE_WIDTH)} property="og:image:width" />
              <meta
                content={String(OG_IMAGE_HEIGHT)}
                property="og:image:height"
              />
              <meta content={pageTitle} property="og:image:alt" />
            </>
          )}
          <meta content={resolvedOgImage} name="twitter:image" />
          {ogGenerated && <meta content={pageTitle} name="twitter:image:alt" />}
        </>
      )
    }
    <meta content={twitterCard} name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    {description && <meta content={description} name="twitter:description" />}
    {xSite && <meta content={xSite} name="twitter:site" />}
    {xCreator && <meta content={xCreator} name="twitter:creator" />}
    {
      bannerKey && (
        <script data-key={bannerKey} is:inline set:html={BANNER_INIT_SCRIPT} />
      )
    }
    <script data-mode={themeMode} is:inline set:html={THEME_INIT_SCRIPT} />
    <Analytics analytics={analytics} />
  </head>
  <body class="bg-background font-sans text-foreground antialiased">
    <a
      class="absolute start-[-999px] top-0 z-[100] bg-accent px-4 py-2 text-accent-foreground focus:start-0"
      href="#blume-content">{strings.page.skipToContent}</a
    >
    <Banner banner={banner} strings={strings.banner} />
    <Header
      askEnabled={askEnabled}
      askStrings={strings.ask}
      hasSidebar={false}
      localeSwitch={localeSwitch}
      logo={logo}
      navStrings={navStrings}
      navigation={navigation}
      route={route}
      searchEnabled={searchEnabled}
      searchLocale={searchLocale}
      searchStrings={strings.search}
      site={site}
      switcherStrings={strings.languageSwitcher}
    />
    <main id="blume-content"><slot /></main>
    <slot name="footer" />
    {
      // Mobile nav for chrome-only pages: the header's inline tab bar is hidden
      // below `lg` and there's no sidebar drawer, so surface the tabs in a
      // slide-in drawer instead. It reuses the header's `data-blume-nav-toggle`
      // machinery (drawer top, scroll lock, resize-close) — the hamburger button
      // lives in the header; this is the panel it opens.
      navigation.tabs.length > 0 && (
        <>
          <aside
            aria-label={navStrings.navigation}
            class="fixed top-[var(--blume-drawer-top,4rem)] start-0 z-[35] h-[calc(100dvh-var(--blume-drawer-top,4rem))] w-64 max-w-[80vw] -translate-x-[105%] overflow-y-auto border-border border-e bg-background px-5 pt-4 pb-6 transition-transform rtl:translate-x-[105%] [:where([data-blume-nav-open])_&]:translate-x-0! lg:hidden"
            data-blume-nav-drawer
          >
            <nav aria-label={navStrings.sections}>
              <ul class="m-0 list-none p-0">
                {navigation.tabs.map((tab) => (
                  <li>
                    <a
                      aria-current={tab === activeTab ? "page" : undefined}
                      class="block rounded-[0.65rem] px-2.5 py-1.5 font-medium text-muted-foreground text-sm transition-colors hover:bg-muted hover:text-foreground aria-[current=page]:bg-muted aria-[current=page]:text-foreground"
                      href={withBase(tab.path)}
                    >
                      {tab.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
          <button
            aria-label={navStrings.closeNavigation}
            class="fixed inset-0 z-[30] hidden cursor-pointer border-0 bg-black/40 [:where([data-blume-nav-open])_&]:block lg:hidden"
            data-blume-nav-toggle
            type="button"
          />
        </>
      )
    }
    {
      clientDataJson && (
        <script
          id="blume-client-data"
          is:inline
          set:html={clientDataJson}
          type="application/json"
        />
      )
    }
    <script>
      // Dev-only: friendly hint after a React island hydration mismatch;
      // tree-shaken out of production builds.
      import "./hydration-hint.ts";

      // The closed tabs drawer is only translated off-canvas, so its links
      // would stay in the tab order. Mirror the header's `data-blume-nav-open`
      // toggle into `inert`/`aria-hidden` below `lg` (64rem), matching the
      // breakpoint where the drawer is display-hidden anyway.
      const drawer = document.querySelector<HTMLElement>(
        "[data-blume-nav-drawer]"
      );
      if (drawer) {
        const desktop = window.matchMedia("(min-width: 64rem)");
        const syncDrawer = () => {
          const hidden =
            !desktop.matches &&
            !document.documentElement.hasAttribute("data-blume-nav-open");
          drawer.inert = hidden;
          if (hidden) {
            drawer.setAttribute("aria-hidden", "true");
          } else {
            drawer.removeAttribute("aria-hidden");
          }
        };
        syncDrawer();
        desktop.addEventListener("change", syncDrawer);
        new MutationObserver(syncDrawer).observe(document.documentElement, {
          attributeFilter: ["data-blume-nav-open"],
        });
      }
    </script>
  </body>
</html>
