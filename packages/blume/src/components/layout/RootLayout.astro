---
import { EN_UI } from "../../core/i18n-ui.ts";
import type { UIStrings } from "../../core/i18n-ui.ts";
import type { BlumeClientData } from "../../core/data.ts";
import type {
  Heading,
  LocaleSwitchOption,
  Navigation,
} from "../../core/types.ts";
import "blume:theme";
import type { ComponentOverride } from "../../core/define-components.ts";
import {
  OG_IMAGE_HEIGHT,
  OG_IMAGE_TYPE,
  OG_IMAGE_WIDTH,
} from "../../og/dimensions.ts";
import { buildStructuredData, toIso } from "../../seo/jsonld.ts";
import { normalizeXHandle } from "../../seo/x-handle.ts";
import { withBase } from "../islands/base-path.ts";
import Analytics from "./Analytics.astro";
import Banner from "./Banner.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import Empty from "./Empty.astro";
import Favicon from "./Favicon.astro";
import Fonts from "./Fonts.astro";
import { BANNER_INIT_SCRIPT, THEME_INIT_SCRIPT } from "./head-scripts.ts";
import Header from "./Header.astro";
import Icon from "../Icon.astro";
import {
  activeTabForRoute,
  findBreadcrumbs,
  flattenPages,
  getPagination,
  sidebarForRoute,
} from "./nav-utils.ts";
import NavTree from "./NavTree.astro";
import { resolveSlot } from "./overrides.ts";
import PageActions from "./PageActions.astro";
import PageFeedback from "./PageFeedback.astro";
import Pagination from "./Pagination.astro";
import TableOfContents from "./TableOfContents.astro";

interface Props {
  site: { title: string; description?: string };
  logo?: {
    svg?: string;
    light?: string;
    dark?: string;
    alt: string;
    href: string;
    text?: string;
  } | null;
  favicon?: {
    href: string;
    type?: string;
  } | null;
  appleIcon?: {
    href: string;
    type?: string;
  } | null;
  banner?: {
    content: string;
    link?: { text: string; href: string };
    dismissible: boolean;
    key: string;
  } | null;
  analytics?: {
    posthog?: { host?: string; key: string };
    scripts?: {
      attributes?: Record<string, string>;
      content?: string;
      src?: string;
      strategy?: "async" | "defer";
    }[];
    vercel?: boolean;
  } | null;
  navigation: Navigation;
  mcp?: { name: string; route: string } | null;
  page: { title: string; description?: string; route: string };
  headings: Heading[];
  imageZoom?: boolean;
  codeWrap?: boolean;
  themeMode: "system" | "light" | "dark";
  fontCssVars?: string[];
  searchEnabled: boolean;
  indexable: boolean;
  ogImage?: string | null;
  /**
   * Whether `ogImage` is Blume's generated card (rather than a user `seo.image`).
   * Only the generated card has known dimensions and format, so `og:image:width`
   * / `og:image:height` / `og:image:type` are declared for it alone — asserting
   * 1200x630 PNG over someone's arbitrary JPEG would be a lie crawlers act on.
   */
  ogGenerated?: boolean;
  /**
   * X (Twitter) attribution: `handle` is the site's account (`twitter:site`),
   * `creator` the author's (`twitter:creator`). The rest of the X card is read
   * from `og:*`, so these are the only values X can't infer.
   */
  x?: { creator?: string; handle?: string };
  canonical?: string | null;
  editUrl?: string | null;
  /**
   * Opt this page out of the header's Ask AI trigger. Defaults to whether Ask
   * AI is configured, so pages never wire the trigger up themselves.
   */
  askEnabled?: boolean;
  /** Show the "Was this page helpful?" rating below the content. */
  feedback?: boolean;
  exportPdf?: boolean;
  exportEpub?: boolean;
  feeds?: { title: string; href: string }[];
  siteUrl?: string | null;
  pageType?: string;
  published?: string | Date | null;
  lastModified?: string | null;
  noindex?: boolean;
  structuredDataEnabled?: boolean;
  /** Active locale code for `<html lang>` (defaults to `en`). */
  locale?: string;
  /** Text direction for `<html dir>` (defaults to `ltr`). */
  dir?: "ltr" | "rtl";
  /**
   * Direction of the page content's own language — differs from `dir` on a
   * fallback page (e.g. English content under an RTL locale). Applied to the
   * article so prose punctuation reads correctly; the chrome still mirrors.
   */
  contentDir?: "ltr" | "rtl";
  /** Resolved UI dictionary; English baseline when omitted. */
  ui?: UIStrings;
  /** `hreflang` alternates (absolute URLs) for this page's translations. */
  localeAlternates?: { hreflang: string; href: string }[];
  /** Absolute URL of the default-locale translation, for `hreflang=x-default`. */
  xDefault?: string | null;
  /** Language-switcher entries for the current page. */
  localeSwitch?: LocaleSwitchOption[];
  /**
   * User layout-slot overrides from `components.ts` (`defineComponents`). Each
   * key replaces the matching built-in; unknown keys are ignored. Wired slots:
   * `Header`, `Logo`, `Search`, `Sidebar`, `MobileNav`, `Breadcrumbs`,
   * `TableOfContents`, `Pagination`, `Feedback`, plus the content-injection slots
   * `PageHeader`, `PageFooter`, and `Footer` (which have no built-in and render
   * only when overridden). `Layout` (replacing this whole component) is wired in
   * the generated page templates, not here.
   */
  layout?: Record<string, ComponentOverride>;
  /**
   * Snapshot serialized for React island hooks (`blume/hooks`). Rendered into a
   * JSON `<script>` when present; omitted for zero-JS pages that need no islands.
   */
  clientData?: BlumeClientData | null;
  /** Table-of-contents settings (`toc` config): visibility + heading range. */
  toc?: { enabled: boolean; maxLevel: number; minLevel: number };
  /**
   * Content-column preset. `"bare"` (the generated changelog index) drops both
   * the sidebar and the table of contents and centers a single wide column;
   * everything else uses the standard sidebar + content + TOC grid.
   */
  contentLayout?: "default" | "bare";
}

const {
  site,
  logo,
  favicon,
  appleIcon,
  banner,
  analytics,
  navigation,
  mcp,
  page,
  headings,
  imageZoom = true,
  codeWrap = false,
  themeMode,
  fontCssVars,
  searchEnabled,
  indexable,
  ogImage,
  ogGenerated = false,
  x,
  canonical,
  editUrl,
  askEnabled,
  feedback = false,
  exportPdf,
  exportEpub,
  feeds,
  siteUrl,
  pageType,
  published,
  lastModified,
  noindex,
  structuredDataEnabled,
  locale = "en",
  dir = "ltr",
  contentDir,
  ui,
  localeAlternates,
  xDefault,
  localeSwitch,
  layout = {},
  clientData,
  toc = { enabled: true, maxLevel: 3, minLevel: 2 },
  contentLayout = "default",
} = Astro.props;

// Serialized once for island hooks; `<` escaped so content can't break the tag.
const clientDataJson = clientData
  ? JSON.stringify(clientData).replaceAll("<", "\\u003c")
  : null;

// Layout-slot overrides: render the user's component when configured, else the
// built-in. Each override receives the same props as the component it replaces.
// `Logo` and `Search` are resolved inside the header (forwarded via `layout`).
const HeaderSlot = resolveSlot(layout.Header, Header);
const SidebarSlot = resolveSlot(layout.Sidebar, NavTree);
const BreadcrumbsSlot = resolveSlot(layout.Breadcrumbs, Breadcrumbs);
const TableOfContentsSlot = resolveSlot(layout.TableOfContents, TableOfContents);
const PaginationSlot = resolveSlot(layout.Pagination, Pagination);
// The mobile drawer reuses the sidebar unless a distinct `MobileNav` is given.
const MobileNavSlot = layout.MobileNav
  ? resolveSlot(layout.MobileNav, NavTree)
  : null;
// Content-injection slots with no built-in: the `Empty` fallback renders nothing
// when unconfigured, so these are safe to render unconditionally.
const FooterSlot = resolveSlot(layout.Footer, Empty);
const PageHeaderSlot = resolveSlot(layout.PageHeader, Empty);
const PageFooterSlot = resolveSlot(layout.PageFooter, Empty);
// The "Was this page helpful?" rating (rendered only when `feedback` is on).
const FeedbackSlot = resolveSlot(layout.Feedback, PageFeedback);

const strings = ui ?? EN_UI;
// Merge the groups this layout reads directly over the English defaults so a
// key missing from a translation (or from a not-yet-regenerated snapshot)
// still renders instead of coming out blank — the PageActions pattern.
const navStrings = { ...EN_UI.nav, ...strings.nav };
const actionStrings = { ...EN_UI.actions, ...strings.actions };
const contentStrings = { ...EN_UI.content, ...strings.content };
// Filter search to the active language only when the site is multi-locale.
const searchLocale =
  localeSwitch && localeSwitch.length > 1 ? locale : undefined;
// TOC entries: the configured heading range, or none when the TOC is disabled
// (an empty list makes TableOfContents render nothing).
// API operation pages own a two-column body (docs + request panel) and their own
// right rail, so they drop the table of contents and widen the content column.
const isApiOperation = pageType === "openapi-operation";
// A "bare" page (the changelog index) is a standalone landing: no sidebar, no
// TOC, just a wider centered column of content.
const isBare = contentLayout === "bare";
const showSidebar = !isBare;
const showToc = !(isApiOperation || isBare);
const tocHeadings =
  toc.enabled && showToc
    ? headings.filter((h) => h.depth >= toc.minLevel && h.depth <= toc.maxLevel)
    : [];
let gridClass =
  "lg:grid-cols-[17.5rem_minmax(0,1fr)] xl:grid-cols-[17.5rem_minmax(0,1fr)_17.5rem]";
if (isBare) {
  gridClass = "";
} else if (isApiOperation) {
  gridClass = "lg:grid-cols-[17.5rem_minmax(0,1fr)]";
}
let articleClass = "prose mx-auto max-w-content";
if (isBare) {
  articleClass = "prose mx-auto max-w-[54rem]";
} else if (isApiOperation) {
  articleClass = "prose max-w-none";
}
const pageTitle = page.title ? `${page.title} - ${site.title}` : site.title;
const description = page.description ?? site.description;
// Blog posts and changelog entries are dated writing, so they take `og:type:
// article` — the same split JSON-LD makes when it picks an article @type. Docs
// pages (and the changelog index, which has no `type`) stay `website`.
const ogType =
  pageType === "blog" || pageType === "changelog" ? "article" : "website";
// `article:*` timestamps only belong on an article; a docs page carrying them
// would be declaring properties its `og:type` doesn't define.
const articlePublished = ogType === "article" ? toIso(published) : undefined;
const articleModified = ogType === "article" ? toIso(lastModified) : undefined;
// X sizes the card from `twitter:card`: a large image needs the wide variant,
// and a page with no image still gets a card (the compact `summary`) rather
// than rendering as a bare link.
const twitterCard = ogImage ? "summary_large_image" : "summary";
// Normalized here, not just in the config schema: a page's `seo.x.creator`
// arrives as raw frontmatter (the collections carry no schema), so the schema's
// transform never touches it — `creator: guestauthor` still needs its `@`.
const xSite = normalizeXHandle(x?.handle);
const xCreator = normalizeXHandle(x?.creator);

// "Last updated on <date>" — formatted in UTC to match the changelog timeline.
const lastModifiedDate = lastModified ? new Date(lastModified) : null;
const formattedLastModified =
  lastModifiedDate && !Number.isNaN(lastModifiedDate.getTime())
    ? new Intl.DateTimeFormat(locale || "en", {
        dateStyle: "long",
        timeZone: "UTC",
      }).format(lastModifiedDate)
    : null;

// The hosted MCP server's absolute URL, used by the page-actions install menu.
// Needs a configured site to be useful, so the menu is hidden without one.
const mcpUrl =
  mcp && siteUrl ? new URL(withBase(mcp.route), siteUrl).href : null;

// Scope the sidebar (and the breadcrumbs/pagination derived from it) to the
// active tab's section, so a multi-section site drills each tab into its own
// pages. Without tabs — or on a route under none — this is the full sidebar.
const sidebar = sidebarForRoute(navigation.sidebar, navigation.tabs, page.route);
const activeTab = activeTabForRoute(navigation.tabs, page.route);
const crumbs = findBreadcrumbs(sidebar, page.route);
const { prev, next } = getPagination(flattenPages(sidebar), page.route);

// Structured data is skipped when disabled or for pages we ask crawlers not to
// index. Escape `<` so a title/description containing `</script>` can't break
// out of the inline JSON-LD tag.
const structuredData =
  structuredDataEnabled === false || noindex
    ? null
    : buildStructuredData({
      base: import.meta.env.BASE_URL,
      breadcrumbs: crumbs,
      description,
      locale,
      modified: lastModified,
      pageType,
      published,
      route: page.route,
      siteName: site.title,
      siteUrl: siteUrl ?? null,
      title: page.title,
    });
const structuredDataJson = structuredData
  ? JSON.stringify(structuredData).replaceAll("<", "\\u003c")
  : null;

const bannerKey = banner?.dismissible ? banner.key : null;
---

<!doctype html>
<html dir={dir} lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <Favicon favicon={favicon} appleIcon={appleIcon} />
    <Fonts cssVars={fontCssVars ?? []} />
    {/* Google warns against pairing a canonical with noindex — the canonical
        says "index that URL", the robots meta says "distrust this page". */}
    {canonical && !noindex && <link rel="canonical" href={canonical} />}
    {
      localeAlternates?.map((alt) => (
        <link href={alt.href} hreflang={alt.hreflang} rel="alternate" />
      ))
    }
    {xDefault && <link href={xDefault} hreflang="x-default" rel="alternate" />}
    {noindex && <meta name="robots" content="noindex" />}
    {description && <meta name="description" content={description} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    {canonical && <meta property="og:url" content={canonical} />}
    {
      articlePublished && (
        <meta property="article:published_time" content={articlePublished} />
      )
    }
    {
      articleModified && (
        <meta property="article:modified_time" content={articleModified} />
      )
    }
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          {ogGenerated && (
            <>
              <meta property="og:image:type" content={OG_IMAGE_TYPE} />
              <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
              <meta
                property="og:image:height"
                content={String(OG_IMAGE_HEIGHT)}
              />
              <meta property="og:image:alt" content={pageTitle} />
            </>
          )}
          <meta name="twitter:image" content={ogImage} />
          {ogGenerated && <meta name="twitter:image:alt" content={pageTitle} />}
        </>
      )
    }
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {xSite && <meta name="twitter:site" content={xSite} />}
    {xCreator && <meta name="twitter:creator" content={xCreator} />}
    {
      feeds?.map((feed) => (
        <link
          href={withBase(feed.href)}
          rel="alternate"
          title={feed.title}
          type="application/rss+xml"
        />
      ))
    }
    {
      structuredDataJson && (
        <script
          is:inline
          set:html={structuredDataJson}
          type="application/ld+json"
        />
      )
    }
    {
      bannerKey && (
        <script data-key={bannerKey} is:inline set:html={BANNER_INIT_SCRIPT} />
      )
    }
    <script data-mode={themeMode} is:inline set:html={THEME_INIT_SCRIPT} />
    <Analytics analytics={analytics} />
  </head>
  <body
    class="bg-background font-sans text-foreground antialiased"
    data-blume-code-wrap={codeWrap ? "" : undefined}
    data-blume-image-zoom={imageZoom ? "" : undefined}
    data-i18n-copy-code={actionStrings.copyCode}
    data-i18n-diagram-error={contentStrings.diagramError}
  >
    <a
      class="absolute start-[-999px] top-0 z-[100] bg-accent px-4 py-2 text-accent-foreground focus:start-0"
      href="#blume-content">{strings.page.skipToContent}</a
    >
    <Banner banner={banner} strings={strings.banner} />
    <HeaderSlot
      askEnabled={askEnabled}
      askStrings={strings.ask}
      layout={layout}
      localeSwitch={localeSwitch}
      logo={logo}
      navigation={navigation}
      route={page.route}
      searchEnabled={searchEnabled}
      searchLocale={searchLocale}
      navStrings={navStrings}
      searchStrings={strings.search}
      site={site}
      switcherStrings={strings.languageSwitcher}
    />
    <div
      class:list={["mx-auto grid grid-cols-1 items-start", gridClass]}
      data-blume-doc-grid
    >
      <aside
        aria-label={navStrings.primary}
        data-blume-nav-drawer
        class:list={[
          "fixed top-[var(--blume-drawer-top,4rem)] start-0 z-[35] h-[calc(100dvh-var(--blume-drawer-top,4rem))] w-64 max-w-[80vw] -translate-x-[105%] overflow-y-auto border-border border-e bg-background px-5 pt-4 pb-6 transition-transform rtl:translate-x-[105%] [:where([data-blume-nav-open])_&]:translate-x-0! lg:sticky lg:top-16 lg:z-auto lg:h-[calc(100dvh-4rem)] lg:w-auto lg:max-w-none lg:translate-x-0! lg:border-e-0 lg:bg-transparent lg:px-4",
          // A "bare" landing (the changelog index) has no sidebar column on
          // desktop, but the header hamburger still needs a drawer to open on
          // mobile — without it the toggle only locked page scroll.
          !showSidebar && "lg:hidden",
        ]}
      >
        {
          // Pinned links (blog, changelog, contact…) sit above every section on
          // all breakpoints, outside the tab-scoped sidebar so they never change
          // with the active tab. External hrefs open in a new tab.
          navigation.featured.length > 0 && (
            <nav
              aria-label={navStrings.featured}
              class="mb-4 border-border border-b pb-4"
            >
              <ul class="m-0 list-none p-0">
                {navigation.featured.map((link) => {
                  const external = /^https?:\/\//u.test(link.href);
                  return (
                    <li>
                      <a
                        class="block rounded-[0.65rem] px-2.5 py-1.5 text-muted-foreground text-sm transition-colors hover:bg-muted hover:text-foreground"
                        href={withBase(link.href)}
                        rel={external ? "noreferrer" : undefined}
                        target={external ? "_blank" : undefined}
                      >
                        <span class="flex items-center gap-2">
                          {link.icon && (
                            <Icon
                              class="shrink-0 text-muted-foreground"
                              name={link.icon}
                              size={14}
                            />
                          )}
                          <span class="flex-1 truncate">{link.label}</span>
                          {external && (
                            <Icon
                              class="shrink-0 text-muted-foreground opacity-60"
                              name="arrow-up-right"
                              size={12}
                            />
                          )}
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </nav>
          )
        }
        {
          // The header's tab bar is hidden below `md`, so the drawer is the only
          // way to move between sections on mobile: list the tabs above the
          // page tree, separated by a divider. Hidden from `md` up, where the
          // header tabs take over — unless the page tree is empty (a tab-scoped
          // standalone page like the changelog), where they keep the drawer
          // from opening blank.
          navigation.tabs.length > 0 && (
            <nav
              aria-label={navStrings.sections}
              class:list={[
                "mb-4 border-border border-b pb-4",
                sidebar.length > 0 && "md:hidden",
              ]}
            >
              <ul class="m-0 list-none p-0">
                {navigation.tabs.map((tab) => (
                  <li>
                    <a
                      aria-current={tab === activeTab ? "page" : undefined}
                      class="block rounded-[0.65rem] px-2.5 py-1.5 font-medium text-muted-foreground text-sm transition-colors hover:bg-muted hover:text-foreground aria-[current=page]:bg-muted aria-[current=page]:text-foreground"
                      href={withBase(tab.href ?? tab.path)}
                    >
                      {tab.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
        <nav>
          {
            MobileNavSlot ? (
              <>
                <div class="lg:hidden">
                  <MobileNavSlot
                    currentRoute={page.route}
                    items={sidebar}
                    strings={navStrings}
                  />
                </div>
                <div class="hidden lg:block">
                  <SidebarSlot
                    currentRoute={page.route}
                    items={sidebar}
                    strings={navStrings}
                  />
                </div>
              </>
            ) : (
              <SidebarSlot
                currentRoute={page.route}
                items={sidebar}
                strings={navStrings}
              />
            )
          }
        </nav>
      </aside>
      <main class="px-6 pt-6 pb-10 lg:px-8 xl:px-10" id="blume-content">
        <BreadcrumbsSlot
          crumbs={crumbs}
          strings={navStrings}
          wide={isApiOperation}
        />
        <TableOfContentsSlot
          headings={tocHeadings}
          title={strings.toc.title}
          variant="mobile"
        />
        <PageHeaderSlot headings={tocHeadings} page={page} route={page.route} />
        <article class:list={[articleClass]} dir={contentDir}>
          <slot />
        </article>
        {
          !isApiOperation && (
            <>
              <PageFooterSlot
                headings={tocHeadings}
                page={page}
                route={page.route}
              />
              {formattedLastModified && (
                <p class="mx-auto mt-10 max-w-content text-muted-foreground text-sm">
                  {strings.page.lastUpdated} {formattedLastModified}
                </p>
              )}
              {feedback && <FeedbackSlot strings={strings.feedback} />}
              <PaginationSlot next={next} prev={prev} strings={strings.page} />
            </>
          )
        }
      </main>
      {
        showToc && (
          <aside
            aria-label={strings.toc.title}
            class="sticky top-16 hidden h-[calc(100dvh-4rem)] overflow-y-auto px-4 pt-6 pb-10 text-sm xl:block"
            data-blume-toc
          >
            <TableOfContentsSlot
              headings={tocHeadings}
              title={strings.toc.title}
              variant="desktop"
            />
            <PageActions
              editUrl={editUrl}
              exportEpub={exportEpub}
              exportPdf={exportPdf}
              mcpName={mcp?.name}
              mcpUrl={mcpUrl}
              route={page.route}
              strings={strings.actions}
            />
          </aside>
        )
      }
    </div>
    <FooterSlot navigation={navigation} site={site} ui={strings} />
    {
      clientDataJson && (
        <script
          id="blume-client-data"
          is:inline
          set:html={clientDataJson}
          type="application/json"
        />
      )
    }
    <button
      aria-label={navStrings.closeNavigation}
      class="fixed inset-0 z-[30] hidden cursor-pointer border-0 bg-black/40 [:where([data-blume-nav-open])_&]:block lg:hidden"
      data-blume-nav-toggle
      type="button"
    ></button>
    <script>
      import { chromeIcons as icons } from "../../theme/chrome-icons.ts";
      // Registers the <blume-mermaid> custom element (emitted by ```mermaid
      // fences). Mermaid itself is lazy-loaded only on pages that use a diagram.
      import "../content/mermaid-element.ts";
      // Registers the <blume-toc> custom element: scrollspy for the table of
      // contents, highlighting the section currently in view as you scroll.
      import "./toc-element.ts";
      // Dev-only: adds a friendly hint after a React island hydration mismatch.
      // Tree-shaken out of production builds.
      import "./hydration-hint.ts";

      // The closed mobile drawer is only translated off-canvas, so its links
      // would stay in the tab order on every page. Mirror the header's
      // `data-blume-nav-open` toggle into `inert`/`aria-hidden` — but only
      // below `lg` (64rem), where the same element isn't the static sidebar.
      const drawer = document.querySelector<HTMLElement>(
        "[data-blume-nav-drawer]"
      );
      if (drawer) {
        const desktop = window.matchMedia("(min-width: 64rem)");
        const syncDrawer = () => {
          const hidden =
            !desktop.matches &&
            !document.documentElement.hasAttribute("data-blume-nav-open");
          drawer.inert = hidden;
          if (hidden) {
            drawer.setAttribute("aria-hidden", "true");
          } else {
            drawer.removeAttribute("aria-hidden");
          }
        };
        syncDrawer();
        desktop.addEventListener("change", syncDrawer);
        new MutationObserver(syncDrawer).observe(document.documentElement, {
          attributeFilter: ["data-blume-nav-open"],
        });
      }

      const svg = (name: string) =>
        `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icons[name]}</svg>`;

      const buttonClass =
        "absolute right-3 inline-flex size-7 items-center justify-center rounded-full bg-transparent text-muted-foreground opacity-70 transition hover:bg-muted hover:text-foreground hover:opacity-100 focus-visible:opacity-100";

      // Localized copy-button label, stamped on <body> by the layout markup
      // (the Search.astro data-attribute channel) since this bundled script
      // can't interpolate server values directly.
      const copyCodeLabel =
        document.body.getAttribute("data-i18n-copy-code") || "Copy code";

      const languageLabels: Record<string, string> = {
        astro: "Astro",
        bash: "Bash",
        css: "CSS",
        html: "HTML",
        js: "JavaScript",
        json: "JSON",
        jsx: "JSX",
        md: "Markdown",
        mdx: "MDX",
        plaintext: "Text",
        sh: "Shell",
        shell: "Shell",
        ts: "TypeScript",
        tsx: "TSX",
        txt: "Text",
        yaml: "YAML",
        yml: "YAML",
        zsh: "Zsh",
      };

      for (const pre of document.querySelectorAll(".prose pre")) {
        if (pre.querySelector("[data-blume-copy]")) {
          continue;
        }
        // Skip nested <pre>: Twoslash renders each hover popup's type signature
        // as a <pre> inside the code block, which shouldn't get its own button.
        if (pre.parentElement?.closest("pre")) {
          continue;
        }
        const language = pre.getAttribute("data-language");
        if (language) {
          pre.setAttribute(
            "data-language",
            languageLabels[language.toLowerCase()] ?? language
          );
        }
        pre.classList.add("group", "relative");
        const button = document.createElement("button");
        button.type = "button";
        // The language-label bar (prose) vs flush code (tabs) need a different
        // offset; pick the Tailwind class by context instead of a CSS override.
        const topClass = pre.closest("blume-tabs, .not-prose")
          ? "top-2.5"
          : "top-2";
        button.className = `${buttonClass} ${topClass}`;
        button.setAttribute("data-blume-copy", "");
        button.setAttribute("aria-label", copyCodeLabel);
        button.innerHTML = svg("copy");
        button.addEventListener("click", async () => {
          const code = pre.querySelector("code");
          let text = code?.textContent ?? "";
          // Twoslash nests each hover popup's type signature and docs inside
          // the <code>; copying textContent verbatim would interleave them
          // with the source. Strip the popups from a clone first.
          if (code?.querySelector(".twoslash-popup-container")) {
            const clone = code.cloneNode(true) as HTMLElement;
            for (const popup of clone.querySelectorAll(
              ".twoslash-popup-container"
            )) {
              popup.remove();
            }
            text = clone.textContent ?? "";
          }
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }
          button.innerHTML = svg("check");
          setTimeout(() => {
            button.innerHTML = svg("copy");
          }, 1500);
        });
        pre.appendChild(button);
      }

      // Click-to-zoom for content images (gated by `markdown.imageZoom`).
      // Enhances every `.prose img` so plain Markdown images open in a lightbox.
      // Opt out per-image with `data-no-zoom`.
      const zoomImages: Iterable<HTMLImageElement> =
        document.body.hasAttribute("data-blume-image-zoom")
          ? document.querySelectorAll<HTMLImageElement>(
              ".prose img:not([data-no-zoom])"
            )
          : [];
      const zoomTargets = Array.from(zoomImages);
      if (zoomTargets.length > 0) {
        const reduceMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;
        let active: {
          clone: HTMLImageElement;
          original: HTMLImageElement;
          overlay: HTMLElement;
        } | null = null;

        const closeZoom = () => {
          if (!active) {
            return;
          }
          const { clone, original, overlay } = active;
          active = null;
          overlay.style.opacity = "0";
          clone.style.transform = "translate(0px, 0px) scale(1)";
          const cleanup = () => {
            overlay.remove();
            original.style.visibility = "";
            document.removeEventListener("keydown", onKey);
            window.removeEventListener("scroll", closeZoom);
          };
          if (reduceMotion) {
            cleanup();
          } else {
            clone.addEventListener("transitionend", cleanup, { once: true });
          }
        };

        const onKey = (event: KeyboardEvent) => {
          if (event.key === "Escape") {
            closeZoom();
          }
        };

        const openZoom = (image: HTMLImageElement) => {
          if (active) {
            return;
          }
          const start = image.getBoundingClientRect();
          if (start.width === 0 || start.height === 0) {
            return;
          }

          const overlay = document.createElement("div");
          overlay.className =
            "fixed inset-0 z-[100] flex cursor-zoom-out items-center justify-center bg-background/80 opacity-0 backdrop-blur-sm transition-opacity duration-300";

          const clone = image.cloneNode(true) as HTMLImageElement;
          clone.className = "absolute m-0 max-w-none rounded-blume shadow-2xl";
          clone.style.top = `${start.top}px`;
          clone.style.left = `${start.left}px`;
          clone.style.width = `${start.width}px`;
          clone.style.height = `${start.height}px`;
          clone.style.transformOrigin = "top left";
          if (!reduceMotion) {
            clone.style.transition =
              "transform 300ms cubic-bezier(0.22, 1, 0.36, 1)";
          }

          overlay.appendChild(clone);
          document.body.appendChild(overlay);
          image.style.visibility = "hidden";
          active = { clone, original: image, overlay };

          const margin = 0.92;
          const ratio = start.width / start.height;
          let targetWidth = window.innerWidth * margin;
          let targetHeight = targetWidth / ratio;
          if (targetHeight > window.innerHeight * margin) {
            targetHeight = window.innerHeight * margin;
            targetWidth = targetHeight * ratio;
          }
          const naturalWidth = image.naturalWidth || targetWidth;
          if (targetWidth > naturalWidth) {
            targetWidth = naturalWidth;
            targetHeight = targetWidth / ratio;
          }
          const scale = targetWidth / start.width;
          const dx = (window.innerWidth - targetWidth) / 2 - start.left;
          const dy = (window.innerHeight - targetHeight) / 2 - start.top;

          requestAnimationFrame(() => {
            overlay.style.opacity = "1";
            clone.style.transform = `translate(${dx}px, ${dy}px) scale(${scale})`;
          });

          overlay.addEventListener("click", closeZoom);
          document.addEventListener("keydown", onKey);
          window.addEventListener("scroll", closeZoom, { passive: true });
        };

        for (const image of zoomTargets) {
          image.classList.add("cursor-zoom-in");
          image.addEventListener("click", () => openZoom(image));
        }
      }
    </script>
  </body>
</html>
