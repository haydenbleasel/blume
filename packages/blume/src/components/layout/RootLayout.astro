---
import type { Heading, Navigation } from "../../core/types.ts";
import "blume:theme";
import Icon from "../Icon.astro";
import { buildStructuredData } from "../../seo/jsonld.ts";
import { findBreadcrumbs, flattenPages, getPagination } from "./nav-utils.ts";
import NavTree from "./NavTree.astro";
import PageActions from "./PageActions.astro";
import Search from "./Search.astro";

interface Props {
  site: { title: string; description?: string };
  logo?: {
    svg?: string;
    light?: string;
    dark?: string;
    alt: string;
    href: string;
  } | null;
  banner?: {
    content: string;
    link?: { text: string; href: string };
    dismissible: boolean;
    key: string;
  } | null;
  navigation: Navigation;
  page: { title: string; description?: string; route: string };
  headings: Heading[];
  themeMode: "system" | "light" | "dark";
  searchEnabled: boolean;
  searchProvider: "orama" | "pagefind";
  indexable: boolean;
  ogImage?: string | null;
  canonical?: string | null;
  editUrl?: string | null;
  repoUrl?: string | null;
  askEnabled?: boolean;
  feeds?: { title: string; href: string }[];
  siteUrl?: string | null;
  pageType?: string;
  published?: string | Date | null;
  noindex?: boolean;
  structuredDataEnabled?: boolean;
}

const {
  site,
  logo,
  banner,
  navigation,
  page,
  headings,
  themeMode,
  searchEnabled,
  searchProvider,
  indexable,
  ogImage,
  canonical,
  editUrl,
  repoUrl,
  askEnabled,
  feeds,
  siteUrl,
  pageType,
  published,
  noindex,
  structuredDataEnabled,
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const pageTitle = page.title ? `${page.title} - ${site.title}` : site.title;
const description = page.description ?? site.description;

// The logo is resolved upstream: an inline `svg` (so a currentColor mark
// follows the theme) or image URL(s) for an <img>.
const logoSvg = logo?.svg;
const logoLight = logo?.light;
const logoDark = logo?.dark ?? logo?.light;
const logoAlt = logo?.alt ?? "";
const brandHref = logo?.href ?? "/";

const crumbs = findBreadcrumbs(navigation.sidebar, page.route);
const { prev, next } = getPagination(
  flattenPages(navigation.sidebar),
  page.route
);
const eyebrowCrumb = crumbs.length > 1 ? crumbs[crumbs.length - 2] : null;

// Structured data is skipped when disabled or for pages we ask crawlers not to
// index. Escape `<` so a title/description containing `</script>` can't break
// out of the inline JSON-LD tag.
const structuredData =
  structuredDataEnabled === false || noindex
    ? null
    : buildStructuredData({
      breadcrumbs: crumbs,
      description,
      pageType,
      published,
      route: page.route,
      siteName: site.title,
      siteUrl: siteUrl ?? null,
      title: page.title,
    });
const structuredDataJson = structuredData
  ? JSON.stringify(structuredData).replaceAll("<", "\\u003c")
  : null;

const iconButton =
  "inline-flex size-9 cursor-pointer items-center justify-center rounded-full text-muted-foreground transition-colors hover:bg-muted hover:text-foreground";

const initialThemeScript = `(()=>{const m=${JSON.stringify(themeMode)};const s=localStorage.getItem("blume-theme");const sys=matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light";document.documentElement.dataset.theme=s??(m==="system"?sys:m);})();`;
// Toggling the theme flips colors; without suppressing transitions the
// animated styles fade while the non-animated ones snap, so we disable all
// transitions for the swap (next-themes' disableTransitionOnChange trick),
// force a synchronous style flush, then restore them on the next tick.
const toggleScript = `document.addEventListener("click",(e)=>{const t=e.target.closest("[data-blume-theme-toggle]");if(t){const d=document.documentElement;const next=d.dataset.theme==="dark"?"light":"dark";const s=document.createElement("style");s.appendChild(document.createTextNode("*,*::before,*::after{transition:none!important}"));document.head.appendChild(s);d.dataset.theme=next;localStorage.setItem("blume-theme",next);window.getComputedStyle(d).opacity;setTimeout(()=>document.head.removeChild(s),1);}const n=e.target.closest("[data-blume-nav-toggle]");if(n){document.documentElement.toggleAttribute("data-blume-nav-open");}const b=e.target.closest("[data-blume-banner-dismiss]");if(b){const bar=b.closest("[data-blume-banner]");const k=bar&&bar.getAttribute("data-banner-key");if(k){localStorage.setItem("blume-banner:"+k,"1");}document.documentElement.setAttribute("data-blume-banner-hidden","");}});`;

// Pre-paint: hide a previously-dismissed banner before it flashes in.
const bannerScript = banner?.dismissible
  ? `(()=>{if(localStorage.getItem("blume-banner:"+${JSON.stringify(banner.key)}))document.documentElement.setAttribute("data-blume-banner-hidden","");})();`
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex" />}
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta name="twitter:image" content={ogImage} />
          <meta name="twitter:card" content="summary_large_image" />
        </>
      )
    }
    {
      feeds?.map((feed) => (
        <link
          href={feed.href}
          rel="alternate"
          title={feed.title}
          type="application/rss+xml"
        />
      ))
    }
    {
      structuredDataJson && (
        <script
          is:inline
          set:html={structuredDataJson}
          type="application/ld+json"
        />
      )
    }
    {bannerScript && <script is:inline set:html={bannerScript} />}
    <script is:inline set:html={initialThemeScript} />
  </head>
  <body class="bg-background font-sans text-foreground antialiased">
    <a
      class="absolute left-[-999px] top-0 z-[100] bg-accent px-4 py-2 text-accent-foreground focus:left-0"
      href="#blume-content">Skip to content</a
    >
    {
      banner && (
        <div
          class="relative flex items-center justify-center gap-x-2 gap-y-0.5 bg-foreground px-10 py-3 text-center text-background text-sm max-sm:flex-wrap [:where([data-blume-banner-hidden])_&]:hidden"
          data-banner-key={banner.key}
          data-blume-banner
        >
          <span>{banner.content}</span>
          {banner.link && (
            <a
              class="inline-flex items-center gap-1 font-medium underline underline-offset-2"
              href={banner.link.href}
            >
              {banner.link.text}
              <Icon name="arrow-right" size={14} />
            </a>
          )}
          {banner.dismissible && (
            <button
              aria-label="Dismiss announcement"
              class="absolute right-1.5 inline-flex size-7 items-center justify-center rounded-full text-background/80 transition-colors hover:bg-white/10 hover:text-background"
              data-blume-banner-dismiss
              type="button"
            >
              <Icon name="x" size={16} />
            </button>
          )}
        </div>
      )
    }
    <header
      class="sticky top-0 z-40 flex h-16 items-center gap-3 bg-background/90 px-4 backdrop-blur md:px-6"
    >
      <button
        aria-label="Toggle navigation"
        class={`${iconButton} lg:hidden`}
        data-blume-nav-toggle
        type="button"
      >
        <Icon name="menu" size={20} />
      </button>
      <a
        class="inline-flex items-center gap-2 font-semibold text-base text-foreground"
        href={brandHref}
      >
        {
          logoSvg && (
            <span
              aria-hidden="true"
              class="inline-flex h-5 items-center [&>svg]:h-5 [&>svg]:w-auto"
              set:html={logoSvg}
            />
          )
        }
        {
          !logoSvg &&
            logoLight &&
            (logoLight === logoDark ? (
              <img alt={logoAlt} class="h-5 w-auto" src={logoLight} />
            ) : (
              <>
                <img alt={logoAlt} class="h-5 w-auto dark:hidden" src={logoLight} />
                <img
                  alt={logoAlt}
                  class="hidden h-5 w-auto dark:block"
                  src={logoDark}
                />
              </>
            ))
        }
        {site.title}
      </a>
      {
        navigation.tabs.length > 0 && (
          <nav aria-label="Sections" class="hidden gap-1 md:flex">
            {navigation.tabs.map((tab) => (
              <a
                aria-current={
                  page.route === tab.path ||
                  (tab.path !== "/" && page.route.startsWith(tab.path))
                    ? "page"
                    : undefined
                }
                class="rounded-full px-3 py-1.5 font-medium text-muted-foreground text-sm transition-colors hover:bg-muted hover:text-foreground aria-[current=page]:text-foreground"
                href={tab.path}
              >
                {tab.label}
              </a>
            ))}
          </nav>
        )
      }
      <div class="flex-1"></div>
      <slot name="ask" />
      {searchEnabled && <Search provider={searchProvider} />}
      <button aria-label="Toggle color theme" class={iconButton} data-blume-theme-toggle type="button">
        <span class="inline-flex dark:hidden"><Icon name="sun" size={18} /></span>
        <span class="hidden dark:inline-flex"><Icon name="moon" size={18} /></span>
      </button>
    </header>
    <div class="mx-auto grid grid-cols-1 items-start lg:grid-cols-[17.5rem_minmax(0,1fr)] xl:grid-cols-[17.5rem_minmax(0,1fr)_16rem]">
      <aside
        aria-label="Primary"
        class="fixed top-16 left-0 z-[35] h-[calc(100dvh-4rem)] w-64 max-w-[80vw] -translate-x-[105%] overflow-y-auto border-border border-r bg-background px-5 pt-4 pb-6 transition-transform [:where([data-blume-nav-open])_&]:translate-x-0 lg:sticky lg:z-auto lg:w-auto lg:max-w-none lg:translate-x-0 lg:border-r-0 lg:bg-transparent lg:px-4"
      >
        <nav>
          <NavTree currentRoute={page.route} items={navigation.sidebar} />
        </nav>
      </aside>
      <main class="min-w-0 px-6 pt-6 pb-10 lg:px-8 xl:px-10" id="blume-content">
        {
          eyebrowCrumb && (
            <nav
              aria-label="Breadcrumb"
              class="mx-auto mb-2 max-w-[42rem] text-muted-foreground text-sm"
            >
              {eyebrowCrumb.route ? (
                <a class="hover:text-foreground" href={eyebrowCrumb.route}>
                  {eyebrowCrumb.label}
                </a>
              ) : (
                <span>{eyebrowCrumb.label}</span>
              )}
            </nav>
          )
        }
        <article class="prose mx-auto max-w-[42rem]">
          <slot />
        </article>
        {
          (prev || next) && (
            <nav
              aria-label="Pagination"
              class="mx-auto mt-12 flex max-w-[42rem] justify-between gap-4 border-border border-t pt-6 max-md:flex-col"
            >
              {prev ? (
                <a
                  class="flex max-w-[48%] flex-1 items-center gap-2 rounded-full border border-border px-4 py-3 text-foreground transition-colors hover:border-foreground max-md:max-w-full"
                  href={prev.route}
                >
                  <Icon name="arrow-left" size={16} />
                  <span>
                    <span class="block text-muted-foreground text-xs">
                      Previous
                    </span>
                    <span class="block font-medium">{prev.label}</span>
                  </span>
                </a>
              ) : (
                <span />
              )}
              {next && (
                <a
                  class="ml-auto flex max-w-[48%] flex-1 items-center justify-end gap-2 rounded-full border border-border px-4 py-3 text-right text-foreground transition-colors hover:border-foreground max-md:max-w-full"
                  href={next.route}
                >
                  <span>
                    <span class="block text-muted-foreground text-xs">Next</span>
                    <span class="block font-medium">{next.label}</span>
                  </span>
                  <Icon name="arrow-right" size={16} />
                </a>
              )}
            </nav>
          )
        }
      </main>
      <aside
        aria-label="On this page"
        class="sticky top-16 hidden h-[calc(100dvh-4rem)] overflow-y-auto px-4 pt-6 pb-10 text-sm xl:block"
      >
        {
          tocHeadings.length > 0 && (
            <>
              <p class="mb-3 font-semibold text-foreground text-sm">
                On this page
              </p>
              <ul class="m-0 list-none p-0">
                {tocHeadings.map((heading) => (
                  <li style={`padding-left:${(heading.depth - 2) * 0.75}rem`}>
                    <a
                      class="block py-1.5 text-muted-foreground transition-colors hover:text-foreground"
                      href={`#${heading.slug}`}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </>
          )
        }
        <PageActions
          askEnabled={askEnabled}
          editUrl={editUrl}
          repoUrl={repoUrl}
          route={page.route}
        />
      </aside>
    </div>
    <button
      aria-label="Close navigation"
      class="fixed inset-0 z-[30] hidden cursor-pointer border-0 bg-black/40 [:where([data-blume-nav-open])_&]:block lg:hidden"
      data-blume-nav-toggle
      type="button"
    ></button>
    <script is:inline set:html={toggleScript} />
    <script>
      import { icons } from "../../theme/icons.ts";

      const svg = (name: string) =>
        `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icons[name]}</svg>`;

      const buttonClass =
        "absolute right-3 inline-flex size-7 items-center justify-center rounded-full bg-transparent text-muted-foreground opacity-70 transition hover:bg-muted hover:text-foreground hover:opacity-100 focus-visible:opacity-100";

      const languageLabels: Record<string, string> = {
        astro: "Astro",
        bash: "Bash",
        css: "CSS",
        html: "HTML",
        js: "JavaScript",
        json: "JSON",
        jsx: "JSX",
        md: "Markdown",
        mdx: "MDX",
        plaintext: "Text",
        sh: "Shell",
        shell: "Shell",
        ts: "TypeScript",
        tsx: "TSX",
        txt: "Text",
        yaml: "YAML",
        yml: "YAML",
        zsh: "Zsh",
      };

      for (const pre of document.querySelectorAll(".prose pre")) {
        if (pre.querySelector("[data-blume-copy]")) {
          continue;
        }
        const language = pre.getAttribute("data-language");
        if (language) {
          pre.setAttribute(
            "data-language",
            languageLabels[language.toLowerCase()] ?? language
          );
        }
        pre.classList.add("group", "relative");
        const button = document.createElement("button");
        button.type = "button";
        // The language-label bar (prose) vs flush code (tabs) need a different
        // offset; pick the Tailwind class by context instead of a CSS override.
        const topClass = pre.closest("blume-tabs, .not-prose")
          ? "top-2.5"
          : "top-2";
        button.className = `${buttonClass} ${topClass}`;
        button.setAttribute("data-blume-copy", "");
        button.setAttribute("aria-label", "Copy code");
        button.innerHTML = svg("copy");
        button.addEventListener("click", async () => {
          const text = pre.querySelector("code")?.textContent ?? "";
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }
          button.innerHTML = svg("check");
          setTimeout(() => {
            button.innerHTML = svg("copy");
          }, 1500);
        });
        pre.appendChild(button);
      }
    </script>
  </body>
</html>
