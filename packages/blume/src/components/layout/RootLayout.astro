---
import { createSatteriMarkdownProcessor } from "@astrojs/markdown-satteri";

import type { Heading, Navigation } from "../../core/types.ts";
import "blume:theme";
import Icon from "../Icon.astro";
import DirectoryListing from "./DirectoryListing.astro";
import {
  findBreadcrumbs,
  findDirectoryListing,
  flattenPages,
  getPagination,
} from "./nav-utils.ts";
import NavTree from "./NavTree.astro";
import PageActions from "./PageActions.astro";
import Search from "./Search.astro";

type ContextualOption =
  | string
  | {
      description?: string;
      href?: string;
      icon?: string;
      title: string;
    };

interface BannerConfig {
  color?: { dark?: string; light?: string };
  content: string;
  dismissible: boolean;
  type: "info" | "warning" | "critical";
}

interface Props {
  banner?: BannerConfig | null;
  site: {
    title: string;
    description?: string;
    favicon?: string | { dark?: string; light?: string } | null;
    logo?:
      | string
      | { alt?: string; dark?: string; href?: string; light?: string }
      | null;
  };
  navigation: Navigation;
  page: {
    canonical?: string;
    contentType?: string;
    title: string;
    deprecated?: boolean;
    description?: string;
    route: string;
    hideFooterPagination?: boolean;
    keywords?: string[];
    metaTags?: Record<string, string>;
    mode?: string;
    noindex?: boolean;
    robots?: string;
    rss?: boolean;
    seoTitle?: string;
    toc?:
      | boolean
      | { maxHeadingLevel?: number; minHeadingLevel?: number };
  };
  headings: Heading[];
  contextual?: { display?: "header" | "toc"; options?: ContextualOption[] };
  footer?: {
    links?: {
      header?: string;
      items?: { href: string; label: string }[];
    }[];
    socials?: Record<string, string>;
  };
  navbar?: {
    links?: {
      href: string;
      icon?: string;
      label: string;
      type?: "github" | "discord";
    }[];
    primary?: {
      href: string;
      label: string;
      type?: "button" | "github" | "discord";
    };
  };
  seo?: {
    metatags?: Record<string, string>;
  };
  styling?: {
    eyebrows?: "breadcrumbs" | "section";
  };
  showPageHeader?: boolean;
  themeMode: "system" | "light" | "dark";
  themeStrict: boolean;
  searchEnabled: boolean;
  searchPrompt?: string;
  searchProvider: "orama" | "pagefind";
  indexable: boolean;
  ogImage?: string | null;
  editUrl?: string | null;
  repoUrl?: string | null;
  askEnabled?: boolean;
}

const {
  banner: baseBanner,
  site,
  navigation,
  page,
  headings,
  contextual,
  footer: baseFooter,
  navbar: baseNavbar,
  seo,
  styling,
  showPageHeader = false,
  themeMode,
  themeStrict,
  searchEnabled,
  searchPrompt,
  searchProvider,
  indexable,
  ogImage,
  editUrl,
  repoUrl,
  askEnabled,
} = Astro.props;

const pageModes = new Set(["center", "custom", "default", "frame", "wide"]);
const pageMode = page.mode && pageModes.has(page.mode) ? page.mode : "default";
const layoutHasSidebar = pageMode !== "custom" && pageMode !== "center";
const layoutHasSidePanel = pageMode === "default";
const layoutHasFooter = pageMode !== "custom";
const layoutHasPageActions = pageMode !== "custom" && pageMode !== "frame";
const tocConfig = page.toc ?? true;
const tocMinHeadingLevel =
  tocConfig && typeof tocConfig === "object"
    ? (tocConfig.minHeadingLevel ?? 2)
    : 2;
const tocMaxHeadingLevel =
  tocConfig && typeof tocConfig === "object"
    ? (tocConfig.maxHeadingLevel ?? 3)
    : 3;
const tocHeadings =
  tocConfig === false || !layoutHasSidePanel
    ? []
    : headings.filter(
        (h) => h.depth >= tocMinHeadingLevel && h.depth <= tocMaxHeadingLevel
      );
const isApiPage = page.contentType === "api";
const pageTitle =
  page.seoTitle ?? (page.title ? `${page.title} - ${site.title}` : site.title);
const description = page.description ?? site.description;
const logo = site.logo;
const logoHref = typeof logo === "object" && logo?.href ? logo.href : "/";
const logoAlt =
  typeof logo === "object" && logo?.alt ? logo.alt : `${site.title} home page`;
const favicon = site.favicon;
const faviconLight =
  typeof favicon === "string" ? favicon : (favicon?.light ?? favicon?.dark);
const faviconDark = typeof favicon === "string" ? null : favicon?.dark;
const propertyMetaPrefixes = ["article:", "book:", "og:", "profile:"];
type MetaTag = {
  content: string;
  key: string;
  property: boolean;
};
const toMetaTag = ([key, content]: [string, string]): MetaTag => ({
    content,
    key,
    property: propertyMetaPrefixes.some((prefix) => key.startsWith(prefix)),
});
const globalMetaTags = Object.entries(seo?.metatags ?? {}).map(toMetaTag);
const pageMetaTags = Object.entries(page.metaTags ?? {}).map(toMetaTag);
const globalCanonical = seo?.metatags?.canonical;
const pageCanonical = page.canonical ?? page.metaTags?.canonical;
const canonicalHref =
  pageCanonical ??
  (globalCanonical
    ? `${globalCanonical.replace(/\/$/, "")}${page.route === "/" ? "" : page.route}`
    : null);
const keywordContent = page.keywords?.length ? page.keywords.join(", ") : null;
const robots =
  page.robots ?? (page.noindex === true || !indexable ? "noindex" : null);
const mergedMetaTags = [
  ...new Map(
    [...globalMetaTags, ...pageMetaTags]
      .filter((tag) => tag.key !== "canonical")
      .filter((tag) => tag.key !== "keywords" || !keywordContent)
      .filter((tag) => tag.key !== "robots" || !robots)
      .map((tag) => [tag.key, tag])
  ).values(),
];
const hasMetaTag = (key: string): boolean =>
  mergedMetaTags.some((tag) => tag.key === key);
const renderDefaultMeta = (key: string): boolean => !hasMetaTag(key);

const isActivePath = (path: string): boolean =>
  page.route === path || (path !== "/" && page.route.startsWith(`${path}/`));
const activeChromeVariant = [...(navigation.chromeVariants ?? [])]
  .filter((variant) => isActivePath(variant.path))
  .sort((a, b) => b.path.length - a.path.length)[0];
const banner = activeChromeVariant?.banner ?? baseBanner;
const footer = activeChromeVariant?.footer ?? baseFooter;
const navbar = activeChromeVariant?.navbar ?? baseNavbar;
const activeSidebarVariant = [...(navigation.sidebarVariants ?? [])]
  .filter((variant) => variant.sidebar.length > 0 && isActivePath(variant.path))
  .sort((a, b) => b.path.length - a.path.length)[0];
const activeSidebar = activeSidebarVariant?.sidebar ?? navigation.sidebar;
const crumbs = findBreadcrumbs(activeSidebar, page.route);
const directoryListing = findDirectoryListing(activeSidebar, page.route);
const { prev, next } = getPagination(flattenPages(activeSidebar), page.route);
const eyebrowStyle = styling?.eyebrows ?? "section";
const eyebrowCrumbs =
  layoutHasSidebar && eyebrowStyle === "breadcrumbs" && crumbs.length > 1
    ? crumbs
    : layoutHasSidebar && crumbs.length > 1
      ? [crumbs[crumbs.length - 2]]
      : [];
const contextualOptions = contextual?.options ?? [];
type ContextualAction = {
  action: string;
  description?: string;
  href?: string;
  icon: string;
  id: string;
  title: string;
};
const builtinContextualActions: Record<string, ContextualAction> = {
  "add-mcp": {
    action: "copy-mcp-command",
    description: "Copy the MCP install command.",
    icon: "puzzle-piece",
    id: "add-mcp",
    title: "Copy MCP install command",
  },
  aistudio: {
    action: "ai",
    description: "Open this page as context in Google AI Studio.",
    icon: "external-link",
    id: "aistudio",
    title: "Open in Google AI Studio",
  },
  assistant: {
    action: "assistant",
    description: "Open the assistant with this page as context.",
    icon: "search",
    id: "assistant",
    title: "Ask assistant",
  },
  chatgpt: {
    action: "ai",
    description: "Open this page as context in ChatGPT.",
    icon: "external-link",
    id: "chatgpt",
    title: "Open in ChatGPT",
  },
  claude: {
    action: "ai",
    description: "Open this page as context in Claude.",
    icon: "external-link",
    id: "claude",
    title: "Open in Claude",
  },
  copy: {
    action: "copy-page",
    description: "Copy this page text for use as context.",
    icon: "copy",
    id: "copy",
    title: "Copy page",
  },
  cursor: {
    action: "editor-mcp",
    description: "Install the hosted MCP server in Cursor.",
    icon: "external-link",
    id: "cursor",
    title: "Connect to Cursor",
  },
  devin: {
    action: "ai",
    description: "Open this page as context in Devin.",
    icon: "external-link",
    id: "devin",
    title: "Open in Devin",
  },
  "devin-mcp": {
    action: "editor-mcp",
    description: "Install the hosted MCP server in Devin.",
    icon: "external-link",
    id: "devin-mcp",
    title: "Connect to Devin",
  },
  "devin-desktop": {
    action: "ai",
    description: "Open this page as context in Devin Desktop.",
    icon: "external-link",
    id: "devin-desktop",
    title: "Open in Devin Desktop",
  },
  "download-pdf": {
    action: "download-pdf",
    description: "Print or save this page as a PDF.",
    icon: "file",
    id: "download-pdf",
    title: "Download PDF",
  },
  "download-spec": {
    action: "download-spec",
    description: "Open the API spec for download.",
    icon: "file",
    id: "download-spec",
    title: "Download API spec",
  },
  downloadApiSpec: {
    action: "download-spec",
    description: "Open the API spec for download.",
    icon: "file",
    id: "downloadApiSpec",
    title: "Download API spec",
  },
  grok: {
    action: "ai",
    description: "Open this page as context in Grok.",
    icon: "external-link",
    id: "grok",
    title: "Open in Grok",
  },
  mcp: {
    action: "copy-mcp-url",
    description: "Copy the hosted MCP server URL.",
    icon: "puzzle-piece",
    id: "mcp",
    title: "Copy MCP server URL",
  },
  perplexity: {
    action: "ai",
    description: "Open this page as context in Perplexity.",
    icon: "external-link",
    id: "perplexity",
    title: "Open in Perplexity",
  },
  view: {
    action: "view-markdown",
    description: "Open this page as Markdown.",
    icon: "file",
    id: "view",
    title: "View as Markdown",
  },
  vscode: {
    action: "editor-mcp",
    description: "Install the hosted MCP server in VS Code.",
    icon: "external-link",
    id: "vscode",
    title: "Connect to VS Code",
  },
  windsurf: {
    action: "ai",
    description: "Open this page as context in Windsurf.",
    icon: "external-link",
    id: "windsurf",
    title: "Open in Windsurf",
  },
};
const contextualActionFor = (
  option: ContextualOption
): ContextualAction | null => {
  if (typeof option === "string") {
    return builtinContextualActions[option] ?? null;
  }
  return {
    action: option.href ? "custom-link" : "copy-page",
    description: option.description,
    href: option.href,
    icon: option.icon ?? "external-link",
    id: `custom-${option.title.toLowerCase().replaceAll(/[^a-z0-9]+/gu, "-")}`,
    title: option.title,
  };
};
const contextualActions = contextualOptions.flatMap((option) => {
  const action = contextualActionFor(option);
  return action ? [action] : [];
});
const headerContextualActions =
  layoutHasPageActions && contextual?.display !== "toc"
    ? contextualActions
    : [];
const tocContextualActions =
  layoutHasSidePanel && contextual?.display === "toc"
    ? contextualActions
    : [];
const hasHeaderContextualActions = headerContextualActions.length > 0;
const hasTocContextualActions = tocContextualActions.length > 0;
const rssHref = page.route === "/" ? "/rss.xml" : `${page.route}/rss.xml`;
const hasRssAction = layoutHasPageActions && page.rss === true;
const socialIcon = (name: string): string => {
  const key = name.toLowerCase();
  if (key === "twitter" || key === "x") {
    return "brand-x";
  }
  if (key === "github" || key === "linkedin") {
    return key;
  }
  return "external-link";
};
const socialEntries = Object.entries(footer?.socials ?? {});
const footerLinkGroups = footer?.links ?? [];
const hasFooterContent =
  footerLinkGroups.length > 0 || socialEntries.length > 0;
const navbarLinks = navbar?.links ?? [];
const navbarPrimary = navbar?.primary;
const tabStates = (navigation.tabs ?? []).map((tab) => ({
  ...tab,
  active:
    isActivePath(tab.path) ||
    (tab.items ?? []).some((item) => isActivePath(item.path)),
}));
const selectorStates = (navigation.selectors ?? []).map((selector) => ({
  ...selector,
  active: selector.items.find((item) => isActivePath(item.path)) ?? null,
}));
const hasMobileChromeLinks =
  tabStates.length > 0 || navbarLinks.length > 0 || Boolean(navbarPrimary);
const navbarIcon = (item: { icon?: string; type?: string }): string | null =>
  item.icon ?? (item.type === "github" ? "github" : null);
const linkTarget = (href: string): "_blank" | undefined =>
  href.startsWith("http") ? "_blank" : undefined;
const linkRel = (href: string): "noreferrer" | undefined =>
  href.startsWith("http") ? "noreferrer" : undefined;
const scriptStringLiteral = (value: string): string =>
  JSON.stringify(value)
    .replaceAll("<", "\\u003C")
    .replaceAll(">", "\\u003E")
    .replaceAll("&", "\\u0026")
    .replaceAll("\u2028", "\\u2028")
    .replaceAll("\u2029", "\\u2029");
const escapeRawHtml = (value: string): string =>
  value.replaceAll("<", "&lt;").replaceAll(">", "&gt;");

const unwrapParagraph = (html: string): string => {
  const trimmed = html.trim();
  const match = trimmed.match(/^<p>(?<content>[\s\S]*)<\/p>$/u);
  return match?.groups?.content ?? trimmed;
};

let bannerHtml = "";
if (banner) {
  const markdownProcessor = await createSatteriMarkdownProcessor();
  const renderedBanner = await markdownProcessor.render(
    escapeRawHtml(banner.content)
  );
  bannerHtml = unwrapParagraph(renderedBanner.code);
}
const bannerColor = banner?.color;
const bannerHasCustomColor = Boolean(bannerColor?.light || bannerColor?.dark);
const bannerStyle = bannerHasCustomColor
  ? `--blume-banner-bg-light:${bannerColor?.light ?? bannerColor?.dark};--blume-banner-bg-dark:${bannerColor?.dark ?? bannerColor?.light};`
  : undefined;
let bannerToneClass = "bg-accent text-accent-foreground";
if (bannerHasCustomColor) {
  bannerToneClass =
    "bg-[var(--blume-banner-bg-light)] text-white dark:bg-[var(--blume-banner-bg-dark)]";
} else if (banner?.type === "warning") {
  bannerToneClass = "bg-amber-500 text-white";
} else if (banner?.type === "critical") {
  bannerToneClass = "bg-red-600 text-white";
}
const bannerKey = banner ? `blume-banner:${banner.content}` : "";

const iconButton =
  "inline-flex size-9 cursor-pointer items-center justify-center rounded-full text-muted-foreground transition-colors hover:bg-muted hover:text-foreground";
const contextualActionClass =
  "flex w-full cursor-pointer items-start gap-3 rounded-blume border-0 bg-transparent px-3 py-2 text-left text-sm text-foreground transition-colors hover:bg-muted focus:outline-none focus:ring-2 focus:ring-accent/25";
const contentGridClass =
  layoutHasSidebar && layoutHasSidePanel
    ? isApiPage
      ? "mx-auto grid grid-cols-1 items-start lg:grid-cols-[17.5rem_minmax(0,1fr)] xl:grid-cols-[17.5rem_minmax(0,1fr)_minmax(20rem,28rem)]"
      : "mx-auto grid grid-cols-1 items-start lg:grid-cols-[17.5rem_minmax(0,1fr)] xl:grid-cols-[17.5rem_minmax(0,1fr)_16rem]"
    : layoutHasSidebar
      ? "mx-auto grid grid-cols-1 items-start lg:grid-cols-[17.5rem_minmax(0,1fr)]"
      : "mx-auto grid w-full grid-cols-1 items-start";
const mainClass =
  pageMode === "custom"
    ? "min-w-0 px-0 py-0"
    : "min-w-0 px-6 py-10 lg:px-8 xl:px-10";
const contentWidthClass =
  pageMode === "custom" || pageMode === "frame"
    ? "max-w-none"
    : pageMode === "wide"
      ? "max-w-5xl"
      : "max-w-[42rem]";
const articleClass = [
  "prose mx-auto",
  contentWidthClass,
  layoutHasSidePanel ? "" : "[&_[data-blume-right-rail-item]]:hidden",
]
  .filter(Boolean)
  .join(" ");
const showPagination =
  layoutHasFooter && !page.hideFooterPagination && Boolean(prev || next);

const initialThemeScript = `(()=>{const m=${JSON.stringify(themeMode)};const s=localStorage.getItem("blume-theme");const sys=matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light";document.documentElement.dataset.theme=s??(m==="system"?sys:m);})();`;
const initialBannerScript =
  banner?.dismissible === true
    ? `(()=>{try{if(localStorage.getItem("blume-banner-dismissed")===${scriptStringLiteral(bannerKey)})document.documentElement.setAttribute("data-blume-banner-hidden","");}catch{}})();`
    : "";
const toggleScript = `document.addEventListener("click",(e)=>{const t=e.target.closest("[data-blume-theme-toggle]");if(t){const d=document.documentElement;const next=d.dataset.theme==="dark"?"light":"dark";d.dataset.theme=next;localStorage.setItem("blume-theme",next);}const n=e.target.closest("[data-blume-nav-toggle]");if(n){document.documentElement.toggleAttribute("data-blume-nav-open");}});`;
const bannerDismissScript =
  banner?.dismissible === true
    ? `document.addEventListener("click",(e)=>{const t=e.target.closest("[data-blume-banner-dismiss]");if(!t)return;const b=t.closest("[data-blume-banner]");if(!b)return;document.documentElement.setAttribute("data-blume-banner-hidden","");try{localStorage.setItem("blume-banner-dismissed",b.dataset.blumeBannerKey??"");}catch{}});`
    : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {
      description &&
        renderDefaultMeta("description") && (
          <meta name="description" content={description} />
        )
    }
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    {robots && <meta name="robots" content={robots} />}
    {
      mergedMetaTags.map((tag) =>
        tag.property ? (
          <meta property={tag.key} content={tag.content} />
        ) : (
          <meta name={tag.key} content={tag.content} />
        )
      )
    }
    {canonicalHref && <link rel="canonical" href={canonicalHref} />}
    {page.rss && <link rel="alternate" type="application/rss+xml" href={rssHref} />}
    {faviconLight && <link rel="icon" href={faviconLight} />}
    {
      faviconDark && (
        <link rel="icon" href={faviconDark} media="(prefers-color-scheme: dark)" />
      )
    }
    {
      renderDefaultMeta("og:title") && (
        <meta property="og:title" content={pageTitle} />
      )
    }
    {
      description &&
        renderDefaultMeta("og:description") && (
          <meta property="og:description" content={description} />
        )
    }
    {
      ogImage && (
        <>
          {
            renderDefaultMeta("og:image") && (
              <meta property="og:image" content={ogImage} />
            )
          }
          {
            renderDefaultMeta("twitter:image") && (
              <meta name="twitter:image" content={ogImage} />
            )
          }
          {
            renderDefaultMeta("twitter:card") && (
              <meta name="twitter:card" content="summary_large_image" />
            )
          }
        </>
      )
    }
    <script is:inline set:html={initialThemeScript} />
    {initialBannerScript && <script is:inline set:html={initialBannerScript} />}
  </head>
  <body class="bg-background font-sans text-foreground antialiased">
    <a
      class="absolute left-[-999px] top-0 z-[100] bg-accent px-4 py-2 text-accent-foreground focus:left-0"
      href="#blume-content">Skip to content</a
    >
    {
      banner && (
        <div
          class={`relative z-50 flex min-h-10 items-center justify-center gap-3 px-4 py-2 text-center text-sm ${bannerToneClass} ${banner.dismissible ? "[:where([data-blume-banner-hidden])_&]:hidden" : ""}`}
          data-blume-banner
          data-blume-banner-key={bannerKey}
          role={banner.type === "critical" ? "alert" : "status"}
          style={bannerStyle}
        >
          <div
            class="max-w-5xl [&_a]:font-medium [&_a]:underline [&_a]:decoration-current/50 [&_a]:underline-offset-4 [&_code]:rounded [&_code]:bg-white/15 [&_code]:px-1 [&_code]:py-0.5"
            set:html={bannerHtml}
          />
          {banner.dismissible && (
            <button
              aria-label="Dismiss banner"
              class="absolute right-2 inline-flex size-7 cursor-pointer items-center justify-center rounded-full text-current/80 transition hover:bg-white/15 hover:text-current"
              data-blume-banner-dismiss
              type="button"
            >
              <Icon name="x" size={16} />
            </button>
          )}
        </div>
      )
    }
    <header
      class="sticky top-0 z-40 flex h-16 items-center gap-3 bg-background/90 px-4 backdrop-blur md:px-6"
    >
      {
        layoutHasSidebar && (
          <button
            aria-label="Toggle navigation"
            class={`${iconButton} lg:hidden`}
            data-blume-nav-toggle
            type="button"
          >
            <Icon name="menu" size={20} />
          </button>
        )
      }
      <a
        class="inline-flex items-center gap-2 font-semibold text-foreground text-sm"
        href={logoHref}
      >
        {
          logo ? (
            typeof logo === "string" ? (
              <img alt={logoAlt} class="h-6 w-auto" src={logo} />
            ) : (
              <>
                {logo.light && (
                  <img
                    alt={logoAlt}
                    class={`h-6 w-auto ${logo.dark ? "dark:hidden" : ""}`}
                    src={logo.light}
                  />
                )}
                {logo.dark && (
                  <img
                    alt={logoAlt}
                    class="hidden h-6 w-auto dark:inline-block"
                    src={logo.dark}
                  />
                )}
                {!logo.light && !logo.dark && site.title}
              </>
            )
          ) : (
            site.title
          )
        }
      </a>
      {
        tabStates.length > 0 && (
          <nav aria-label="Sections" class="hidden gap-1 md:flex">
            {tabStates.map((tab) =>
              tab.items && tab.items.length > 0 ? (
                <details class="group relative">
                  <summary
                    aria-current={tab.active ? "page" : undefined}
                    class="inline-flex cursor-pointer list-none items-center gap-1.5 rounded-full px-3 py-1.5 font-medium text-muted-foreground text-sm transition-colors hover:bg-muted hover:text-foreground aria-[current=page]:text-foreground [&::-webkit-details-marker]:hidden"
                  >
                    {tab.icon && <Icon name={tab.icon} size={15} />}
                    {tab.label}
                    <Icon
                      class="text-muted-foreground transition-transform group-open:rotate-180"
                      name="chevron-down"
                      size={13}
                    />
                  </summary>
                  <div class="absolute top-full left-0 z-50 mt-2 w-72 rounded-blume border border-border bg-background p-1.5 shadow-xl">
                    {tab.items.map((item) => (
                      <a
                        aria-current={isActivePath(item.path) ? "page" : undefined}
                        class="block rounded-blume px-3 py-2 text-foreground text-sm transition-colors hover:bg-muted aria-[current=page]:bg-muted"
                        href={item.path}
                        rel={linkRel(item.path)}
                        target={linkTarget(item.path)}
                      >
                        <span class="flex min-w-0 items-center gap-2">
                          {item.icon && (
