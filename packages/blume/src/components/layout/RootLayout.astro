        plaintext: "Text",
        sh: "Shell",
        shell: "Shell",
        ts: "TypeScript",
        tsx: "TSX",
        txt: "Text",
        yaml: "YAML",
        yml: "YAML",
        zsh: "Zsh",
      };

      const rightRailContent = document.querySelector<HTMLElement>(
        "[data-blume-right-rail-content]"
      );
      const rightRailItems = Array.from(
        document.querySelectorAll<HTMLElement>(
          "article [data-blume-right-rail-item]"
        )
      ).filter(
        (item) => !item.parentElement?.closest("[data-blume-right-rail-item]")
      );
      if (rightRailContent && rightRailItems.length > 0) {
        rightRailContent.replaceChildren();
        if (rightRailItems.some((item) => item.hasAttribute("data-blume-panel"))) {
          document.querySelector("[data-blume-toc]")?.setAttribute("hidden", "");
        }

        for (const item of rightRailItems) {
          const clone = item.cloneNode(true) as HTMLElement;
          item.classList.add("xl:hidden");
          clone.classList.remove("my-6");
          clone.classList.remove("xl:hidden");
          clone.classList.add("my-0");
          rightRailContent.append(clone);
        }
      }

      for (const pre of document.querySelectorAll(".prose pre")) {
        if (pre.querySelector("[data-blume-copy]")) {
          continue;
        }
        const language = pre.getAttribute("data-language");
        if (language) {
          pre.setAttribute(
            "data-language",
            languageLabels[language.toLowerCase()] ?? language
          );
        }
        pre.classList.add("group", "relative");
        const button = document.createElement("button");
        button.type = "button";
        // The language-label bar (prose) vs flush code (tabs) need a different
        // offset; pick the Tailwind class by context instead of a CSS override.
        const topClass = pre.closest("blume-tabs, .not-prose")
          ? "top-2.5"
          : "top-1";
        button.className = `${buttonClass} ${topClass}`;
        button.setAttribute("data-blume-copy", "");
        button.setAttribute("aria-label", "Copy code");
        button.innerHTML = svg("copy");
        button.addEventListener("click", async () => {
          const text = pre.querySelector("code")?.textContent ?? "";
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }
          button.innerHTML = svg("check");
          setTimeout(() => {
            button.innerHTML = svg("copy");
          }, 1500);
        });
        pre.appendChild(button);
      }

      const articleText = () => {
        const article = document.querySelector("article");
        const clone = article?.cloneNode(true) as HTMLElement | undefined;
        clone
          ?.querySelectorAll(
            "[data-blume-contextual-menu], [data-blume-copy-page], [data-blume-right-rail-item]"
          )
          .forEach((element) => element.remove());
        return clone?.innerText.trim() ?? document.title;
      };

      const pageMarkdown = () => {
        const title =
          document.querySelector("article h1")?.textContent?.trim() ??
          document.title;
        const body = articleText();
        return body.startsWith(title) ? body : `# ${title}\n\n${body}`;
      };

      const pagePrompt = () =>
        [
          "Use this documentation page as context.",
          `URL: ${window.location.href}`,
          "",
          pageMarkdown(),
        ].join("\n");

      const mcpServerUrl = () =>
        new URL("/mcp", window.location.origin).toString();

      const updateActionLabel = (
        button: Element,
        label: string,
        timeout = 1500
      ) => {
        const target = button.querySelector("[data-blume-contextual-label]");
        if (!target) {
          return;
        }
        const previous = target.textContent ?? "";
        target.textContent = label;
        setTimeout(() => {
          target.textContent = previous;
        }, timeout);
      };

      const copyToClipboard = async (button: Element, text: string) => {
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          return false;
        }
        updateActionLabel(button, "Copied");
        return true;
      };

      const aiUrl = (tool: string, prompt: string): string => {
        const query = encodeURIComponent(prompt);
        if (tool === "chatgpt") {
          return `https://chatgpt.com/?q=${query}`;
        }
        if (tool === "claude") {
          return `https://claude.ai/new?q=${query}`;
        }
        if (tool === "perplexity") {
          return `https://www.perplexity.ai/search/new?q=${query}`;
        }
        if (tool === "grok") {
          return `https://grok.com/?q=${query}`;
        }
        if (tool === "aistudio") {
          return `https://aistudio.google.com/prompts/new_chat?prompt=${query}`;
        }
        if (tool === "devin") {
          return `https://app.devin.ai/?q=${query}`;
        }
        if (tool === "windsurf" || tool === "devin-desktop") {
          return `https://windsurf.com/editor?prompt=${query}`;
        }
        return `https://www.google.com/search?q=${query}`;
      };

      const mcpInstallUrl = (tool: string): string | null => {
        const name = encodeURIComponent(document.title.split(" - ")[0] || "Docs");
        const config = encodeURIComponent(
          JSON.stringify({ mcpServers: { [name]: { url: mcpServerUrl() } } })
        );
        if (tool === "cursor") {
          return `cursor://anysphere.cursor-deeplink/mcp/install?name=${name}&config=${config}`;
        }
        if (tool === "vscode") {
          return `vscode:mcp/install?name=${name}&config=${config}`;
        }
        if (tool === "devin-mcp") {
          return `https://app.devin.ai/settings/mcp?config=${config}`;
        }
        return null;
      };

      const closeContextualMenu = (button: Element) => {
        const menu = button.closest(
          "details[data-blume-contextual-menu]"
        ) as HTMLDetailsElement | null;
        if (menu) {
          menu.open = false;
        }
      };

      for (const button of document.querySelectorAll(
        "[data-blume-contextual-action]"
      )) {
        button.addEventListener("click", async (event) => {
          const action = button.getAttribute("data-blume-contextual-action");
          const tool = button.getAttribute("data-blume-contextual-tool") ?? "";
          if (action === "custom-link") {
            return;
          }
          event.preventDefault();
          closeContextualMenu(button);

          if (action === "copy-page") {
            await copyToClipboard(button, pageMarkdown());
            return;
          }
          if (action === "view-markdown") {
            const blob = new Blob([pageMarkdown()], {
              type: "text/markdown;charset=utf-8",
            });
            const url = URL.createObjectURL(blob);
            window.open(url, "_blank", "noopener,noreferrer");
            setTimeout(() => URL.revokeObjectURL(url), 30_000);
            return;
          }
          if (action === "ai") {
            window.open(aiUrl(tool, pagePrompt()), "_blank", "noopener,noreferrer");
            return;
          }
          if (action === "copy-mcp-url") {
            await copyToClipboard(button, mcpServerUrl());
            return;
          }
          if (action === "copy-mcp-command") {
            await copyToClipboard(button, `npx add-mcp ${mcpServerUrl()}`);
            return;
          }
          if (action === "editor-mcp") {
            const url = mcpInstallUrl(tool);
            if (url) {
              window.location.href = url;
            }
            return;
          }
          if (action === "assistant") {
            const askButton = Array.from(document.querySelectorAll("button")).find(
              (item) => item.textContent?.trim() === "Ask AI"
            );
            if (askButton instanceof HTMLButtonElement) {
              askButton.click();
            } else {
              await copyToClipboard(button, pagePrompt());
            }
            return;
          }
          if (action === "download-pdf") {
            window.print();
            return;
          }
          if (action === "download-spec") {
            window.open("/openapi.json", "_blank", "noopener,noreferrer");
          }
        });
      }

      for (const button of document.querySelectorAll("[data-blume-copy-page]")) {
        if (button.hasAttribute("data-blume-contextual-action")) {
          continue;
        }
        button.addEventListener("click", async () => {
          const article = document.querySelector("article");
          const clone = article?.cloneNode(true) as HTMLElement | undefined;
          clone
            ?.querySelectorAll("[data-blume-copy-page]")
            .forEach((element) => element.remove());
          const text = clone?.innerText.trim() ?? document.title;
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }

          const label = button.querySelector("[data-blume-copy-page-label]");
          if (!label) {
            return;
          }
          const previous = label.textContent ?? "Copy page";
          label.textContent = "Copied";
          setTimeout(() => {
            label.textContent = previous;
          }, 1500);
        });
      }

      const viewPanels = Array.from(
        document.querySelectorAll<HTMLElement>("[data-blume-view-panel]")
      );
      if (
        viewPanels.length > 1 &&
        !document.querySelector("[data-blume-view-selector]")
      ) {
        const titles = Array.from(
          new Set(
            viewPanels
              .map((panel) => panel.dataset.blumeViewTitle)
              .filter(Boolean)
          )
        ) as string[];
        const saved = localStorage.getItem("blume-view");
        const initial = saved && titles.includes(saved) ? saved : titles[0];

        const buildSelector = (id: string, className: string) => {
          const wrapper = document.createElement("div");
          wrapper.className = className;
          wrapper.setAttribute("data-blume-view-selector", "");

          const label = document.createElement("label");
          label.className = "sr-only";
          label.htmlFor = id;
          label.textContent = "View";

          const select = document.createElement("select");
          select.id = id;
          select.className =
            "rounded-blume border border-border bg-background px-3 py-2 font-medium text-foreground text-sm";
          for (const title of titles) {
            const option = document.createElement("option");
            option.value = title;
            option.textContent = title;
            select.appendChild(option);
          }
          wrapper.append(label, select);
          return { select, wrapper };
        };

        const inlineSelector = buildSelector(
          "blume-view-select",
          "not-prose my-6 flex items-center justify-end gap-2 xl:hidden"
        );
        const railSelector = buildSelector(
          "blume-view-select-rail",
          "mb-6 hidden items-center justify-stretch gap-2 xl:flex"
        );
        const selects = [inlineSelector.select, railSelector.select];
        const viewForHeading = (anchor: HTMLAnchorElement) => {
          const id = decodeURIComponent(anchor.hash.slice(1));
          if (!id) {
            return null;
          }
          return document
            .getElementById(id)
            ?.closest<HTMLElement>("[data-blume-view-panel]");
        };
        const tocItems = Array.from(
          document.querySelectorAll<HTMLElement>("[data-blume-toc-item]")
        ).map((item) => {
          const anchor = item.querySelector<HTMLAnchorElement>("a[href^='#']");
          return {
            item,
            panel: anchor ? viewForHeading(anchor) : null,
          };
        });

        const updateView = (active: string) => {
          for (const select of selects) {
            select.value = active;
          }
          localStorage.setItem("blume-view", active);
          for (const panel of viewPanels) {
            const selected = panel.dataset.blumeViewTitle === active;
            panel.hidden = !selected;
            panel.setAttribute("aria-hidden", selected ? "false" : "true");
          }
          for (const { item, panel } of tocItems) {
            const visible = !panel || panel.dataset.blumeViewTitle === active;
            item.hidden = !visible;
          }
        };

        for (const select of selects) {
          select.addEventListener("change", () => updateView(select.value));
        }
        viewPanels[0].before(inlineSelector.wrapper);
        document
          .querySelector("[data-blume-toc]")
          ?.before(railSelector.wrapper);
        updateView(initial);
      }
    </script>
  </body>
</html>
