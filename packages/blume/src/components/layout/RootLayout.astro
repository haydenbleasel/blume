---
import type { Heading, Navigation } from "../../core/types.ts";
import "blume:theme";
import Icon from "../Icon.astro";
import { findBreadcrumbs, flattenPages, getPagination } from "./nav-utils.ts";
import NavTree from "./NavTree.astro";
import Search from "./Search.astro";

interface Props {
  site: { title: string; description?: string };
  navigation: Navigation;
  page: { title: string; description?: string; route: string };
  headings: Heading[];
  themeMode: "system" | "light" | "dark";
  searchEnabled: boolean;
  indexable: boolean;
  ogImage?: string | null;
}

const {
  site,
  navigation,
  page,
  headings,
  themeMode,
  searchEnabled,
  indexable,
  ogImage,
} = Astro.props;

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const pageTitle = page.title ? `${page.title} - ${site.title}` : site.title;
const description = page.description ?? site.description;

const crumbs = findBreadcrumbs(navigation.sidebar, page.route);
const { prev, next } = getPagination(
  flattenPages(navigation.sidebar),
  page.route
);

const iconButton =
  "inline-flex size-9 cursor-pointer items-center justify-center rounded-blume text-muted-foreground hover:bg-muted hover:text-foreground";

const initialThemeScript = `(()=>{const m=${JSON.stringify(themeMode)};const s=localStorage.getItem("blume-theme");const sys=matchMedia("(prefers-color-scheme: dark)").matches?"dark":"light";document.documentElement.dataset.theme=s??(m==="system"?sys:m);})();`;
const toggleScript = `document.addEventListener("click",(e)=>{const t=e.target.closest("[data-blume-theme-toggle]");if(t){const d=document.documentElement;const next=d.dataset.theme==="dark"?"light":"dark";d.dataset.theme=next;localStorage.setItem("blume-theme",next);}const n=e.target.closest("[data-blume-nav-toggle]");if(n){document.documentElement.toggleAttribute("data-blume-nav-open");}});`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={pageTitle} />
    {description && <meta property="og:description" content={description} />}
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          <meta name="twitter:image" content={ogImage} />
          <meta name="twitter:card" content="summary_large_image" />
        </>
      )
    }
    <script is:inline set:html={initialThemeScript} />
  </head>
  <body class="bg-background font-sans text-foreground antialiased">
    <a
      class="absolute left-[-999px] top-0 z-[100] bg-accent px-4 py-2 text-accent-foreground focus:left-0"
      href="#blume-content">Skip to content</a
    >
    <header
      class="sticky top-0 z-40 flex h-14 items-center gap-4 border-b border-border bg-background/85 px-6 backdrop-blur"
    >
      <button
        aria-label="Toggle navigation"
        class={`${iconButton} md:hidden`}
        data-blume-nav-toggle
        type="button"
      >
        <Icon name="menu" size={20} />
      </button>
      <a class="font-semibold text-foreground" href="/">{site.title}</a>
      {
        navigation.tabs.length > 0 && (
          <nav aria-label="Sections" class="hidden gap-1 md:flex">
            {navigation.tabs.map((tab) => (
              <a
                aria-current={
                  page.route === tab.path ||
                  (tab.path !== "/" && page.route.startsWith(tab.path))
                    ? "page"
                    : undefined
                }
                class="rounded-blume px-3 py-1.5 font-medium text-muted-foreground text-sm hover:bg-muted hover:text-foreground aria-[current=page]:text-accent"
                href={tab.path}
              >
                {tab.label}
              </a>
            ))}
          </nav>
        )
      }
      <div class="flex-1"></div>
      <slot name="ask" />
      {searchEnabled && <Search />}
      <button aria-label="Toggle color theme" class={iconButton} data-blume-theme-toggle type="button">
        <span class="inline-flex dark:hidden"><Icon name="sun" size={18} /></span>
        <span class="hidden dark:inline-flex"><Icon name="moon" size={18} /></span>
      </button>
    </header>
    <div
      class="mx-auto grid max-w-[90rem] grid-cols-1 items-start md:grid-cols-[16rem_minmax(0,1fr)] xl:grid-cols-[16rem_minmax(0,1fr)_15rem]"
    >
      <aside
        aria-label="Primary"
        class="fixed top-14 left-0 z-[35] h-[calc(100dvh-3.5rem)] w-64 max-w-[80vw] -translate-x-[105%] overflow-y-auto border-border border-r bg-background px-4 py-6 transition-transform [:where([data-blume-nav-open])_&]:translate-x-0 md:sticky md:z-auto md:w-auto md:max-w-none md:translate-x-0 md:bg-transparent"
      >
        <nav>
          <NavTree currentRoute={page.route} items={navigation.sidebar} />
        </nav>
      </aside>
      <main class="min-w-0 px-6 py-8 md:px-10" id="blume-content">
        {
          crumbs.length > 1 && (
            <nav
              aria-label="Breadcrumb"
              class="mb-5 flex flex-wrap items-center gap-1.5 text-muted-foreground text-sm"
            >
              {crumbs.map((crumb, i) => (
                <>
                  {i > 0 && (
                    <Icon class="opacity-60" name="chevron-right" size={14} />
                  )}
                  {crumb.route ? (
                    <a class="hover:text-foreground" href={crumb.route}>
                      {crumb.label}
                    </a>
                  ) : (
                    <span>{crumb.label}</span>
                  )}
                </>
              ))}
            </nav>
          )
        }
        <article class="prose max-w-3xl">
          <slot />
        </article>
        {
          (prev || next) && (
            <nav
              aria-label="Pagination"
              class="mt-12 flex justify-between gap-4 border-border border-t pt-6 max-md:flex-col"
            >
              {prev ? (
                <a
                  class="flex max-w-[48%] flex-1 items-center gap-2 rounded-blume border border-border px-4 py-3 text-foreground hover:border-accent max-md:max-w-full"
                  href={prev.route}
                >
                  <Icon name="arrow-left" size={16} />
                  <span>
                    <span class="block text-muted-foreground text-xs">
                      Previous
                    </span>
                    <span class="block font-medium">{prev.label}</span>
                  </span>
                </a>
              ) : (
                <span />
              )}
              {next && (
                <a
                  class="ml-auto flex max-w-[48%] flex-1 items-center justify-end gap-2 rounded-blume border border-border px-4 py-3 text-right text-foreground hover:border-accent max-md:max-w-full"
                  href={next.route}
                >
                  <span>
                    <span class="block text-muted-foreground text-xs">Next</span>
                    <span class="block font-medium">{next.label}</span>
                  </span>
                  <Icon name="arrow-right" size={16} />
                </a>
              )}
            </nav>
          )
        }
      </main>
      {
        tocHeadings.length > 0 && (
          <aside
            aria-label="Table of contents"
            class="sticky top-14 hidden h-[calc(100dvh-3.5rem)] overflow-y-auto px-4 py-6 text-sm xl:block"
          >
            <p class="mb-3 font-semibold text-muted-foreground text-xs uppercase tracking-wide">
              On this page
            </p>
            <ul class="m-0 list-none p-0">
              {tocHeadings.map((heading) => (
                <li style={`padding-left:${(heading.depth - 2) * 0.75}rem`}>
                  <a
                    class="block py-1 text-muted-foreground hover:text-foreground"
                    href={`#${heading.slug}`}
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>
    <button
      aria-label="Close navigation"
      class="fixed inset-0 z-[30] hidden cursor-pointer border-0 bg-black/40 [:where([data-blume-nav-open])_&]:block md:hidden"
      data-blume-nav-toggle
      type="button"
    ></button>
    <script is:inline set:html={toggleScript} />
    <script>
      import { icons } from "../../theme/icons.ts";

      const svg = (name: string) =>
        `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${icons[name]}</svg>`;

      const buttonClass =
        "blume-copy-button absolute right-2 top-2 inline-flex size-8 items-center justify-center rounded-md border border-border bg-background text-muted-foreground opacity-0 transition-opacity group-hover:opacity-100 focus-visible:opacity-100";

      for (const pre of document.querySelectorAll(".prose pre")) {
        if (pre.querySelector(".blume-copy-button")) {
          continue;
        }
        pre.classList.add("group", "relative");
        const button = document.createElement("button");
        button.type = "button";
        button.className = buttonClass;
        button.setAttribute("aria-label", "Copy code");
        button.innerHTML = svg("copy");
        button.addEventListener("click", async () => {
          const text = pre.querySelector("code")?.textContent ?? "";
          try {
            await navigator.clipboard.writeText(text);
          } catch {
            return;
          }
          button.innerHTML = svg("check");
          setTimeout(() => {
            button.innerHTML = svg("copy");
          }, 1500);
        });
        pre.appendChild(button);
      }
    </script>
  </body>
</html>
