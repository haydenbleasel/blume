---
import Icon from "../Icon.astro";

const pagefindUrl = `${import.meta.env.BASE_URL}pagefind/pagefind.js`.replace(
  "//",
  "/"
);
---

<blume-search class="contents" data-pagefind-url={pagefindUrl}>
  <button
    aria-label="Search"
    class="inline-flex h-9 cursor-pointer items-center gap-2 rounded-blume border border-border bg-muted px-2.5 text-muted-foreground text-sm hover:border-accent"
    data-blume-search-open
    type="button"
  >
    <Icon name="search" size={16} />
    <span class="max-sm:hidden">Search</span>
    <kbd
      class="rounded border border-border bg-background px-1.5 py-0.5 font-mono text-[0.7rem] max-sm:hidden"
    >
      ⌘K
    </kbd>
  </button>

  <dialog
    aria-label="Search docs"
    class="mx-auto mt-[12vh] w-[min(36rem,92vw)] rounded-blume border border-border bg-background p-0 text-foreground backdrop:bg-black/40"
    data-blume-search-dialog
  >
    <div class="flex items-center gap-2.5 border-border border-b px-4 py-3.5 text-muted-foreground">
      <Icon name="search" size={18} />
      <input
        aria-label="Search docs"
        class="flex-1 border-0 bg-transparent text-base text-foreground focus:outline-none"
        data-blume-search-input
        placeholder="Search documentation..."
        type="search"
      />
      <kbd class="rounded border border-border px-1.5 py-0.5 font-mono text-[0.7rem]">Esc</kbd>
    </div>
    <ul class="m-0 max-h-[60vh] list-none overflow-y-auto p-2" data-blume-search-results></ul>
    <p class="m-0 px-4 py-5 text-center text-muted-foreground text-sm" data-blume-search-message hidden></p>
  </dialog>

  <script>
    interface PagefindDoc {
      url: string;
      excerpt: string;
      meta?: { title?: string };
    }

    const RESULT_CLASS = "block rounded-blume px-2.5 py-2.5 text-inherit hover:bg-muted hover:no-underline";
    const EXCERPT_CLASS =
      "block text-muted-foreground text-sm [&_mark]:bg-accent/25 [&_mark]:text-inherit";

    class BlumeSearch extends HTMLElement {
      dialog!: HTMLDialogElement;
      input!: HTMLInputElement;
      results!: HTMLElement;
      message!: HTMLElement;
      pagefind: {
        search: (
          q: string
        ) => Promise<{ results: { data: () => Promise<PagefindDoc> }[] }>;
      } | null = null;
      loaded = false;

      connectedCallback() {
        this.dialog = this.querySelector("[data-blume-search-dialog]")!;
        this.input = this.querySelector("[data-blume-search-input]")!;
        this.results = this.querySelector("[data-blume-search-results]")!;
        this.message = this.querySelector("[data-blume-search-message]")!;

        this.querySelector("[data-blume-search-open]")?.addEventListener(
          "click",
          () => this.open()
        );

        document.addEventListener("keydown", (event) => {
          const inField = this.isField(event.target);
          if (
            ((event.key === "k" || event.key === "K") &&
              (event.metaKey || event.ctrlKey)) ||
            (event.key === "/" && !inField)
          ) {
            event.preventDefault();
            this.open();
          }
        });

        this.input.addEventListener("input", () => this.search());
        this.dialog.addEventListener("click", (event) => {
          if (event.target === this.dialog) {
            this.dialog.close();
          }
        });
      }

      isField(target: EventTarget | null): boolean {
        const el = target as HTMLElement | null;
        return Boolean(
          el &&
            (el.tagName === "INPUT" ||
              el.tagName === "TEXTAREA" ||
              el.isContentEditable)
        );
      }

      async open() {
        this.dialog.showModal();
        this.input.focus();
        if (this.loaded) {
          return;
        }
        this.loaded = true;
        try {
          this.pagefind = await import(
            /* @vite-ignore */ this.dataset.pagefindUrl as string
          );
        } catch {
          this.pagefind = null;
          this.setMessage("Search is available in the production build.");
        }
      }

      setMessage(text: string) {
        this.message.textContent = text;
        this.message.hidden = !text;
      }

      async search() {
        const query = this.input.value.trim();
        this.results.replaceChildren();
        if (!query) {
          this.setMessage("");
          return;
        }
        if (!this.pagefind) {
          this.setMessage("Search is available in the production build.");
          return;
        }
        const response = await this.pagefind.search(query);
        const docs = await Promise.all(
          response.results.slice(0, 8).map((result) => result.data())
        );
        this.setMessage(docs.length === 0 ? "No results found." : "");
        for (const doc of docs) {
          const item = document.createElement("li");
          const link = document.createElement("a");
          link.href = doc.url;
          link.className = RESULT_CLASS;
          const title = document.createElement("span");
          title.className = "block font-medium";
          title.textContent = doc.meta?.title ?? doc.url;
          const excerpt = document.createElement("span");
          excerpt.className = EXCERPT_CLASS;
          excerpt.innerHTML = doc.excerpt;
          link.append(title, excerpt);
          item.appendChild(link);
          this.results.appendChild(item);
        }
      }
    }

    if (!customElements.get("blume-search")) {
      customElements.define("blume-search", BlumeSearch);
    }
  </script>
</blume-search>
