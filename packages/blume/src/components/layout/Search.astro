---
import Icon from "../Icon.astro";

// The provider-specific loader is generated per project into `blume:search-client`
// (an alias to `.blume/src/generated/search-client.ts`), so this component is
// provider-agnostic: it lazy-imports that module on first open and uses the
// `SearchFn` it returns. Only the configured provider's SDK is bundled.
---

<blume-search class="contents">
  <button
    aria-label="Search"
    class="inline-flex h-9 min-w-0 cursor-pointer items-center gap-2 rounded-full border border-border bg-background px-3 text-muted-foreground text-sm transition-colors hover:border-foreground hover:text-foreground sm:min-w-48"
    data-blume-search-open
    type="button"
  >
    <Icon name="search" size={16} />
    <span class="min-w-0 flex-1 text-left max-sm:hidden">Search</span>
    <kbd class="font-mono text-[0.7rem] max-sm:hidden" data-blume-search-kbd
      >⌘K</kbd
    >
  </button>

  <dialog
    aria-label="Search docs"
    class="mx-auto mt-[12vh] w-[min(36rem,92vw)] rounded-blume border border-border bg-background p-0 text-foreground shadow-2xl backdrop:bg-black/40"
    data-blume-search-dialog
  >
    <div class="flex items-center gap-2.5 border-border border-b px-4 py-3.5 text-muted-foreground">
      <Icon name="search" size={18} />
      <input
        aria-label="Search docs"
        class="flex-1 border-0 bg-transparent text-base text-foreground focus:outline-none"
        data-blume-search-input
        placeholder="Search documentation..."
        type="search"
      />
      <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[0.7rem]">Esc</kbd>
    </div>
    <ul class="m-0 max-h-[60vh] list-none overflow-y-auto p-2" data-blume-search-results></ul>
    <p class="m-0 px-4 py-5 text-center text-muted-foreground text-sm" data-blume-search-message hidden></p>
  </dialog>

  <script>
    interface SearchHit {
      url: string;
      title: string;
      excerpt: string;
    }
    type SearchFn = (query: string) => Promise<SearchHit[]>;

    const RESULT_CLASS =
      "block rounded-blume px-2.5 py-2.5 text-inherit transition-colors hover:bg-muted hover:no-underline";
    const EXCERPT_CLASS =
      "block text-muted-foreground text-sm [&_mark]:bg-accent/25 [&_mark]:text-inherit";

    class BlumeSearch extends HTMLElement {
      dialog!: HTMLDialogElement;
      input!: HTMLInputElement;
      results!: HTMLElement;
      message!: HTMLElement;
      searchFn: SearchFn | null = null;
      loaded = false;

      connectedCallback() {
        this.dialog = this.querySelector("[data-blume-search-dialog]")!;
        this.input = this.querySelector("[data-blume-search-input]")!;
        this.results = this.querySelector("[data-blume-search-results]")!;
        this.message = this.querySelector("[data-blume-search-message]")!;

        // The handler accepts ⌘K and Ctrl+K; show the right one per platform.
        const kbd = this.querySelector("[data-blume-search-kbd]");
        if (kbd) {
          kbd.textContent = /mac|iphone|ipad|ipod/iu.test(navigator.platform)
            ? "⌘K"
            : "Ctrl K";
        }

        this.querySelector("[data-blume-search-open]")?.addEventListener(
          "click",
          () => this.open()
        );

        document.addEventListener("keydown", (event) => {
          const inField = this.isField(event.target);
          if (
            ((event.key === "k" || event.key === "K") &&
              (event.metaKey || event.ctrlKey)) ||
            (event.key === "/" && !inField)
          ) {
            event.preventDefault();
            this.open();
          }
        });

        this.input.addEventListener("input", () => this.search());
        this.dialog.addEventListener("click", (event) => {
          if (event.target === this.dialog) {
            this.dialog.close();
          }
        });
      }

      isField(target: EventTarget | null): boolean {
        const el = target as HTMLElement | null;
        return Boolean(
          el &&
            (el.tagName === "INPUT" ||
              el.tagName === "TEXTAREA" ||
              el.isContentEditable)
        );
      }

      async open() {
        this.dialog.showModal();
        this.input.focus();
        if (this.loaded) {
          return;
        }
        this.loaded = true;
        try {
          const { createSearch } = await import("blume:search-client");
          this.searchFn = await createSearch();
        } catch {
          this.searchFn = null;
          this.setMessage("Search is available in the production build.");
        }
      }

      setMessage(text: string) {
        this.message.textContent = text;
        this.message.hidden = !text;
      }

      async search() {
        const query = this.input.value.trim();
        this.results.replaceChildren();
        if (!query) {
          this.setMessage("");
          return;
        }
        if (!this.searchFn) {
          this.setMessage("Search is available in the production build.");
          return;
        }
        const hits = await this.searchFn(query);
        this.setMessage(hits.length === 0 ? "No results found." : "");
        for (const hit of hits) {
          const item = document.createElement("li");
          const link = document.createElement("a");
          link.href = hit.url;
          link.className = RESULT_CLASS;
          const title = document.createElement("span");
          title.className = "block font-medium";
          title.textContent = hit.title;
          const excerpt = document.createElement("span");
          excerpt.className = EXCERPT_CLASS;
          excerpt.innerHTML = hit.excerpt;
          link.append(title, excerpt);
          item.appendChild(link);
          this.results.appendChild(item);
        }
      }
    }

    if (!customElements.get("blume-search")) {
      customElements.define("blume-search", BlumeSearch);
    }
  </script>
</blume-search>
