---
import { withBase } from "../islands/base-path.ts";
// The site brand: the logo mark (inline SVG so a `currentColor` mark follows the
// theme, or light/dark `<img>` variants) followed by the site title, wrapped in
// a link to the brand href. Extracted from the header so it can be replaced on
// its own through the `Logo` layout slot (`defineComponents({ layout: { Logo } })`).
import type { BlumeLogo } from "../../core/data.ts";

interface Props {
  site: { title: string };
  logo?: BlumeLogo | null;
}

const { site, logo } = Astro.props;

// The logo is resolved upstream: an inline `svg` (so a currentColor mark follows
// the theme) or image URL(s) for an <img>.
const logoSvg = logo?.svg;
const logoLight = logo?.light;
const logoDark = logo?.dark ?? logo?.light;
const logoLightDimensions = logo?.dimensions?.light;
const logoDarkDimensions = logo?.dimensions?.dark ?? logo?.dimensions?.light;
const logoAlt = logo?.alt ?? "";
const brandHref = logo?.href ?? "/";
// Wordmark beside the mark: the configured `logo.text`, or the site title when
// it's omitted. An explicit `""` hides it (an image-only logo whose mark already
// carries the wordmark).
const brandText = logo?.text ?? site.title;
---

<a
  class="inline-flex items-center gap-2 font-semibold text-base text-foreground"
  href={withBase(brandHref)}
>
  {
    logoSvg && (
      <span
        aria-hidden="true"
        class="inline-flex h-5 items-center [&>svg]:h-5 [&>svg]:w-auto"
        set:html={logoSvg}
      />
    )
  }
  {
    !logoSvg &&
      logoLight &&
      (logoLight === logoDark ? (
        <img
          alt={logoAlt}
          class="h-5 w-auto"
          height={logoLightDimensions?.height}
          src={withBase(logoLight)}
          width={logoLightDimensions?.width}
        />
      ) : (
        <>
          <img
            alt={logoAlt}
            class="h-5 w-auto dark:hidden"
            height={logoLightDimensions?.height}
            src={withBase(logoLight)}
            width={logoLightDimensions?.width}
          />
          <img
            alt={logoAlt}
            class="hidden h-5 w-auto dark:block"
            height={logoDarkDimensions?.height}
            src={withBase(logoDark)}
            width={logoDarkDimensions?.width}
          />
        </>
      ))
  }
  {brandText && <span>{brandText}</span>}
</a>
