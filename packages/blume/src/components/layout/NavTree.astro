---
import type { NavNode } from "../../core/types.ts";
import Self from "./NavTree.astro";

interface Props {
  items: NavNode[];
  currentRoute: string;
}

const { items, currentRoute } = Astro.props;
---

<ul class="m-0 list-none p-0">
  {
    items.map((item) =>
      item.kind === "page" ? (
        <li>
          <a
            aria-current={item.route === currentRoute ? "page" : undefined}
            class="block rounded-blume px-2.5 py-1.5 text-muted-foreground text-sm hover:bg-muted hover:text-foreground aria-[current=page]:bg-accent/15 aria-[current=page]:font-medium aria-[current=page]:text-accent"
            href={item.route}
          >
            {item.label}
          </a>
        </li>
      ) : (
        <li>
          <p class="mt-4 mb-1 font-semibold text-muted-foreground text-xs uppercase tracking-wide">
            {item.label}
          </p>
          <div class="ml-2 border-border border-l pl-2">
            <Self currentRoute={currentRoute} items={item.children} />
          </div>
        </li>
      )
    )
  }
</ul>
