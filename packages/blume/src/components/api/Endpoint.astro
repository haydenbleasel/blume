---
import Icon from "../Icon.astro";

interface Props {
  deprecated?: boolean;
  method: string;
  path: string;
  requestExampleId?: string;
  server?: string;
  tryIt?: boolean;
}

const {
  deprecated = false,
  method,
  path,
  requestExampleId,
  tryIt = true,
} = Astro.props;
const normalized = method.toLowerCase();

const methodColor: Record<string, string> = {
  delete: "bg-red-500/10 text-red-600 dark:text-red-400",
  get: "bg-green-500/10 text-green-600 dark:text-green-400",
  head: "bg-muted text-muted-foreground",
  options: "bg-muted text-muted-foreground",
  patch:
    "bg-amber-500/10 text-amber-700 dark:text-amber-300",
  post: "bg-blue-500/10 text-blue-600 dark:text-blue-400",
  put: "bg-amber-500/10 text-amber-700 dark:text-amber-300",
};
const color = methodColor[normalized] ?? "bg-muted text-foreground";
---

<div
  class="not-prose my-6 flex items-center gap-2 rounded-full border border-border bg-background p-1.5"
>
  <div class="flex min-w-0 flex-1 items-center gap-2.5 px-1">
    <span
      class={`rounded-full px-2.5 py-1 font-mono font-semibold text-xs ${color}`}
    >
      {method.toUpperCase()}
    </span>
    <code class="truncate font-mono text-[0.9rem]">{path}</code>
    {
      deprecated && (
        <span class="shrink-0 rounded-full bg-amber-500/10 px-2 py-1 font-medium text-amber-700 text-xs leading-none dark:text-amber-300">
          deprecated
        </span>
      )
    }
  </div>
  {
    tryIt && requestExampleId && (
      <a
        class="inline-flex shrink-0 items-center gap-1.5 rounded-full bg-action px-3.5 py-2 font-medium text-action-foreground text-sm transition hover:opacity-90"
        href={`#${requestExampleId}`}
      >
        Try it
        <Icon name="arrow-right" size={14} />
      </a>
    )
  }
</div>
