---
import ApiExamplePanel from "./ApiExamplePanel.astro";

interface Props {
  dropdown?: boolean;
  id?: string;
  title?: string;
}

const { dropdown = false, id, title = "Request" } = Astro.props;
---

<ApiExamplePanel dropdown={dropdown} id={id} kind="request" title={title}>
  <slot />
</ApiExamplePanel>
