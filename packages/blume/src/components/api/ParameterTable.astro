---
interface Parameter {
  name: string;
  type?: string;
  required?: boolean;
  description?: string;
}

interface Props {
  title?: string;
  parameters?: Parameter[];
}

const { title, parameters = [] } = Astro.props;
---

<div class="not-prose my-6">
  {title && <p class="mb-2 font-semibold">{title}</p>}
  {
    parameters.length > 0 && (
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr>
            <th class="border border-border px-3 py-2 text-left font-semibold">
              Name
            </th>
            <th class="border border-border px-3 py-2 text-left font-semibold">
              Type
            </th>
            <th class="border border-border px-3 py-2 text-left font-semibold">
              Description
            </th>
          </tr>
        </thead>
        <tbody>
          {parameters.map((parameter) => (
            <tr>
              <td class="border border-border px-3 py-2 align-top">
                <code class="font-mono">{parameter.name}</code>
                {parameter.required && (
                  <span class="ml-1.5 text-red-600 text-xs">required</span>
                )}
              </td>
              <td class="border border-border px-3 py-2 align-top">
                {parameter.type && (
                  <code class="font-mono text-muted-foreground">
                    {parameter.type}
                  </code>
                )}
              </td>
              <td class="border border-border px-3 py-2 align-top text-muted-foreground">
                {parameter.description}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )
  }
  <slot />
</div>
