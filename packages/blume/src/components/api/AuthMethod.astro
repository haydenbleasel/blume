---
interface Props {
  type: string;
  name?: string;
  description?: string;
}

const { type, name, description } = Astro.props;
---

<div class="not-prose my-4 flex flex-wrap items-center gap-2.5">
  <span
    class="inline-flex items-center rounded-full bg-accent/15 px-2 py-0.5 font-medium text-accent text-xs"
  >
    {type}
  </span>
  {name && <code class="font-mono text-sm">{name}</code>}
  {
    description && (
      <p class="m-0! w-full text-muted-foreground text-sm">{description}</p>
    )
  }
</div>
