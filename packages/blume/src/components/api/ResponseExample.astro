---
interface Props {
  title?: string;
}

const { title = "Response" } = Astro.props;
---

<div class="not-prose my-6 overflow-hidden rounded-blume border border-border">
  <div
    class="border-border border-b bg-muted px-3.5 py-2 font-semibold text-muted-foreground text-xs"
  >
    {title}
  </div>
  <div class="px-3.5 [&>pre]:my-3 [&>pre]:overflow-x-auto">
    <slot />
  </div>
</div>
