---
interface Props {
  dropdown?: boolean;
  id?: string;
  kind: "request" | "response";
  title: string;
}

const { dropdown = false, id, kind, title } = Astro.props;
---

<blume-api-example
  class="not-prose my-6 block overflow-hidden rounded-blume border border-border/80 bg-background shadow-sm shadow-border/30"
  data-blume-api-example
  data-blume-request-example={kind === "request" ? "" : undefined}
  data-blume-response-example={kind === "response" ? "" : undefined}
  data-blume-right-rail-item
  data-dropdown={dropdown ? "true" : "false"}
  id={id}
>
  <div
    class="flex min-h-10 items-center justify-between gap-3 border-border/70 border-b bg-muted/35 px-3.5 py-2"
  >
    <p class="m-0 truncate font-medium text-muted-foreground text-xs">
      {title}
    </p>
    <div
      class="flex min-w-0 shrink-0 items-center justify-end gap-1.5"
      data-blume-api-example-controls
    >
    </div>
  </div>
  <div
    class="[&_.astro-code]:!rounded-none [&_.astro-code]:!border-0 [&_pre]:m-0 [&_pre]:max-h-[28rem] [&_pre]:overflow-x-auto [&_pre]:rounded-none [&_pre]:border-0"
    data-blume-api-example-content
  >
    <slot />
  </div>
</blume-api-example>

<script>
  const BUTTON_CLASS =
    "inline-flex h-7 cursor-pointer items-center rounded-md border border-transparent bg-transparent px-2 font-medium text-[0.7rem] text-muted-foreground transition hover:bg-muted hover:text-foreground aria-[selected=true]:border-border aria-[selected=true]:bg-background aria-[selected=true]:text-foreground";
  const SELECT_CLASS =
    "max-w-40 rounded-md border border-border bg-background px-2 py-1 font-medium text-foreground text-xs";
  const SYNC_EVENT = "blume-tabs-change";

  const panelTitle = (panel: HTMLElement, index: number) =>
    panel.dataset.title ?? `Example ${index + 1}`;

  class BlumeApiExample extends HTMLElement {
    #panels: HTMLElement[] = [];
    #ready = false;
    #select: HTMLSelectElement | null = null;
    #triggers: HTMLButtonElement[] = [];

    connectedCallback() {
      if (this.#ready) {
        return;
      }
      this.#ready = true;

      const controls = this.querySelector<HTMLElement>(
        "[data-blume-api-example-controls]"
      );
      const content = this.querySelector<HTMLElement>(
        "[data-blume-api-example-content]"
      );
      const panels = Array.from(
        content?.querySelectorAll<HTMLElement>(":scope > [data-blume-tab-panel]") ??
          []
      );
      if (!controls || panels.length === 0) {
        return;
      }

      controls.replaceChildren();
      this.#panels = panels;

      if (panels.length > 1) {
        if (this.dataset.dropdown === "true") {
          this.#select = document.createElement("select");
          this.#select.className = SELECT_CLASS;
          this.#select.setAttribute("aria-label", "Select code example");
          panels.forEach((panel, index) => {
            const option = document.createElement("option");
            option.value = String(index);
            option.textContent = panelTitle(panel, index);
            this.#select?.appendChild(option);
          });
          this.#select.addEventListener("change", () => {
            this.activate(Number(this.#select?.value ?? "0"), true);
          });
          controls.appendChild(this.#select);
        } else {
          panels.forEach((panel, index) => {
            const trigger = document.createElement("button");
            trigger.type = "button";
            trigger.className = BUTTON_CLASS;
            trigger.textContent = panelTitle(panel, index);
            trigger.setAttribute("aria-selected", index === 0 ? "true" : "false");
            trigger.addEventListener("click", () => {
              this.activate(index, true);
            });
            controls.appendChild(trigger);
            this.#triggers.push(trigger);
          });
        }

        document.addEventListener(SYNC_EVENT, this.#sync);
      }

      this.activate(0, false);
    }

    disconnectedCallback() {
      document.removeEventListener(SYNC_EVENT, this.#sync);
    }

    activate(index: number, sync: boolean) {
      const activePanel = this.#panels[index];
      if (!activePanel) {
        return;
      }

      this.#panels.forEach((panel, panelIndex) => {
        const active = panelIndex === index;
        panel.classList.toggle("hidden", !active);
        panel.setAttribute("aria-hidden", active ? "false" : "true");
      });
      this.#triggers.forEach((trigger, triggerIndex) => {
        trigger.setAttribute(
          "aria-selected",
          triggerIndex === index ? "true" : "false"
        );
      });
      if (this.#select) {
        this.#select.value = String(index);
      }
      if (sync) {
        document.dispatchEvent(
          new CustomEvent(SYNC_EVENT, {
            detail: { title: panelTitle(activePanel, index) },
          })
        );
      }
    }

    #sync = (event: Event) => {
      const title = (event as CustomEvent<{ title?: string }>).detail?.title;
      if (!title) {
        return;
      }
      const index = this.#panels.findIndex(
        (panel, panelIndex) => panelTitle(panel, panelIndex) === title
      );
      if (index !== -1) {
        this.activate(index, false);
      }
    };
  }

  if (!customElements.get("blume-api-example")) {
    customElements.define("blume-api-example", BlumeApiExample);
  }
</script>
