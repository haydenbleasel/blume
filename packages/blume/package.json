{
  "name": "blume",
  "version": "0.0.0",
  "description": "Open-source, markdown-first documentation framework powered by Astro and Vite.",
  "keywords": [
    "astro",
    "docs",
    "documentation",
    "markdown",
    "mdx",
    "vite"
  ],
  "license": "MIT",
  "bin": {
    "blume": "./bin/blume.mjs"
  },
  "files": [
    "src",
    "bin"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/core/schema.ts",
    "./runtime": "./src/runtime/index.ts",
    "./astro": "./src/astro/index.ts",
    "./og": "./src/og/index.ts",
    "./markdown": "./src/markdown/index.ts",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*",
    "./theme/*": "./src/theme/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsgo --noEmit && tsgo -p test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/vercel": "^11.0.0",
    "@orama/orama": "^3.1.18",
    "@scalar/astro": "^0.4.5",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4",
    "@takumi-rs/core": "^1.8.7",
    "@takumi-rs/helpers": "^1.8.7",
    "ai": "^5.0.0",
    "astro": "^7.0.2",
    "citty": "^0.1.6",
    "consola": "^3.4.0",
    "deepmerge": "^4.3.1",
    "gray-matter": "^4.0.3",
    "jiti": "^2.4.0",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "pagefind": "^1.3.0",
    "pathe": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4",
    "tinyglobby": "^0.2.10",
    "typescript": "^5.7.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260626.1",
    "bun-types": "^1.3.14"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
