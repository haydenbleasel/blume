{
  "name": "blume-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo run build --filter=!video",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=!video && changeset publish",
    "bundle-docs": "node packages/blume/scripts/bundle-docs.mjs",
    "prepare": "husky && node packages/blume/scripts/bundle-docs.mjs",
    "bump-deps": "npx npm-check-updates -u --deep && bun i"
  },
  "devDependencies": {
    "@ai-sdk/openai-compatible": "^1.0.41",
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/node": "^11.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/vercel": "^11.0.0",
    "@changesets/cli": "^2.27.0",
    "@mixedbread/sdk": "^0.76.0",
    "@notionhq/client": "^2.2.15",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "@orama/orama": "^3.1.18",
    "@oramacloud/client": "^2.1.0",
    "@pierre/diffs": "^1.2.11",
    "@sanity/client": "^6.21.0",
    "@scalar/astro": "^0.4.5",
    "@shikijs/twoslash": "^4.2.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4",
    "ai": "^5.0.0",
    "algoliasearch": "^5.55.0",
    "astro": "^7.0.2",
    "flexsearch": "^0.8.0",
    "husky": "^9.1.7",
    "katex": "^0.17.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.2.0",
    "tailwindcss": "^4",
    "turbo": "^2.3.0",
    "typescript": "^6.0.3",
    "typesense": "^3.0.0",
    "ultracite": "^7.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14",
  "patchedDependencies": {
    "oxfmt@0.58.0": "patches/oxfmt@0.58.0.patch"
  }
}
