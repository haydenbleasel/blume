---
// The `blume audit` spotlight — the CLI page's marquee feature, below the
// parallax scroll. A full-width terminal shows the real report format (grouped
// findings, source files, fix lines, skipped tiers), followed by three cards:
// source-mapped findings, the CI gate, and the agent handoff.
import { glyph, icons } from "../_home/shared.ts";
import FeatureTerminal from "./FeatureTerminal.astro";

const cards = [
  {
    body: "Because Blume built the site, every finding points at the source file and the front matter line that fixes it — not just the URL a crawler saw. The report reads as a to-do list, not a wall of pages.",
    code: "content/docs/export.mdx:3",
    icon: icons.fileCode,
    title: "Findings that name the fix",
  },
  {
    body: "The exit code is the contract: fail on errors by default, tighten to warnings when you're ready. Point --url at a live deployment to catch what only the real server can tell you — bad rewrites, missing compression, a stray X-Robots-Tag.",
    code: "blume audit --fail-on warning",
    icon: glyph("shield-check"),
    title: "A CI gate you control",
  },
  {
    body: "Hand the findings to Claude Code or Codex. The audit writes the full report and opens your agent with a prompt that fixes each finding at the source, rebuilds, and re-audits until the report is clean.",
    code: "blume audit --claude",
    icon: icons.ai,
    title: "Automagically optimized",
  },
];
---

<section>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="font-medium text-3xl tracking-tight sm:text-4xl">
      Audit everything you ship.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-balance text-muted-foreground">
      blume audit crawls your built site the way a search engine would — titles,
      descriptions, canonicals, Open Graph, structured data, sitemaps — and
      turns what it finds into a to-do list your favorite agent can clear. No
      third-party SEO tools required.
    </p>
  </div>

  <div
    class="mx-auto mt-10 max-w-3xl overflow-hidden rounded-blume border border-zinc-800 shadow-2xl shadow-foreground/10"
  >
    <FeatureTerminal kind="audit" />
  </div>

  <div class="mx-auto mt-8 grid max-w-6xl gap-6 lg:grid-cols-3">
    {
      cards.map((card) => (
        <div class="flex flex-col rounded-blume border border-border p-6 sm:p-8">
          <span class="inline-flex size-10 items-center justify-center rounded-blume bg-muted text-accent">
            <svg
              class="size-5"
              fill="none"
              height="20"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="20"
              set:html={card.icon}
            />
          </span>
          <h3 class="mt-5 font-medium text-foreground text-lg tracking-tight">
            {card.title}
          </h3>
          <p class="mt-3 flex-1 text-muted-foreground text-sm leading-relaxed">
            {card.body}
          </p>
          <code class="mt-5 self-start rounded-md bg-muted px-2.5 py-1.5 font-mono text-foreground text-xs">
            {card.code}
          </code>
        </div>
      ))
    }
  </div>
</section>
