---
// A faithful, static mock of a docs site built with Blume — the fictional
// "Comet" brand (see `sampleBrand` in shared.ts) — framed by a light-grey panel
// it sits into (padded top/left/right, flush bottom).
import { copyIcon, icons, sampleBrand } from "./shared.ts";

const title = sampleBrand.name;
const logoSvg = sampleBrand.logo;

// Code shown in the mock. A string rendered through an Astro expression so the
// JSX/Markdown inside auto-escapes (no hand-written entities).
const mockupCode = `import { Comet } from "comet";

const comet = new Comet(process.env.COMET_API_KEY);

await comet.messages.send({
  to: "ada@example.com",
  template: "welcome",
});`;
---

<section>
  <div
    class="overflow-hidden rounded-[2rem] bg-muted/50 px-4 pt-8 sm:px-12 sm:pt-14"
  >
    <div
      class="overflow-hidden rounded-t-blume border border-border border-b-0 bg-background shadow-2xl shadow-foreground/10"
    >
      <!-- App header -->
      <div
        class="flex items-center justify-between border-border border-b px-5 py-3"
      >
        <div class="flex items-center gap-6">
          <span
            class="flex items-center gap-2 font-medium text-base text-foreground"
          >
            {
              logoSvg && (
                <span
                  aria-hidden="true"
                  class="inline-flex h-5 items-center text-accent [&>svg]:h-5 [&>svg]:w-auto"
                  set:html={logoSvg}
                />
              )
            }
            {title}
          </span>
          <nav
            class="hidden items-center gap-5 text-muted-foreground text-sm sm:flex"
          >
            <span class="text-foreground">Docs</span>
            <span>API</span>
            <span>Changelog</span>
          </nav>
        </div>
        <span
          class="hidden items-center gap-2 rounded-full border border-border px-3 py-1.5 text-[13px] text-muted-foreground sm:flex"
        >
          <svg
            class="size-4"
            fill="none"
            height="16"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="16"
            set:html={icons.search}
          ></svg>
          Search
          <span class="ml-2 rounded border border-border px-1 font-mono">⌘K</span>
        </span>
      </div>
      <!-- Three-pane body -->
      <div
        class="grid min-h-[360px] grid-cols-1 sm:min-h-[520px] sm:grid-cols-[220px_1fr] lg:grid-cols-[220px_1fr_200px]"
      >
        <aside class="hidden border-border border-r p-5 text-[13px] sm:block">
          <p class="font-medium text-foreground">Get started</p>
          <ul class="mt-3 space-y-2 text-muted-foreground">
            <li>Introduction</li>
            <li class="text-accent">Quickstart</li>
            <li>Authentication</li>
          </ul>
          <p class="mt-5 font-medium text-foreground">Sending</p>
          <ul class="mt-3 space-y-2 text-muted-foreground">
            <li>Messages</li>
            <li>Templates</li>
            <li>Webhooks</li>
          </ul>
        </aside>
        <div class="mx-auto min-w-0 max-w-2xl p-6 sm:p-8">
          <p class="text-[13px] text-muted-foreground">Get started</p>
          <h3 class="mt-1 font-semibold text-2xl text-foreground tracking-tight">
            Quickstart
          </h3>
          <p class="mt-3 text-muted-foreground text-sm leading-relaxed">
            Send your first message in minutes. Comet's REST API works with any
            language — here's a request to get you started.
          </p>
          <div
            class="mt-5 flex gap-2.5 rounded-blume border-accent border-l-2 bg-accent/5 p-4"
          >
            <svg
              class="mt-px size-4 shrink-0 text-accent"
              fill="none"
              height="16"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="16"
              set:html={icons.sparkle}
            ></svg>
            <p class="text-[13px] text-foreground leading-relaxed">
              <span class="font-medium">Tip</span> — store your API key in an
              environment variable, never in source.
            </p>
          </div>
          <div class="mt-5 overflow-hidden rounded-blume border border-border">
            <div
              class="flex items-center justify-between border-border border-b bg-muted/40 px-4 py-2 text-[13px] text-muted-foreground"
            >
              <span class="font-mono">send-message.ts</span>
              <svg
                class="size-3.5"
                fill="none"
                height="14"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="14"
                set:html={copyIcon}
              ></svg>
            </div>
            <pre
              class="overflow-x-auto p-4 font-mono text-[13px] text-foreground leading-relaxed"><code>{mockupCode}</code></pre>
          </div>
        </div>
        <aside class="hidden border-border border-l p-5 text-[13px] lg:block">
          <p class="font-medium text-foreground">On this page</p>
          <ul class="mt-3 space-y-2 text-muted-foreground">
            <li class="text-foreground">Install the SDK</li>
            <li>Send a message</li>
            <li>Handle webhooks</li>
          </ul>
        </aside>
      </div>
    </div>
  </div>
  <p
    class="mx-auto mt-6 max-w-md text-balance text-center text-muted-foreground text-sm"
  >
    Navigation, search, theming, and Open Graph images — all generated from a
    folder of Markdown. Nothing to wire up.
  </p>
</section>
