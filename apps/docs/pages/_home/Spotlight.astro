---
// Customer spotlight — a split card in the style of Mintlify's "Powering
// businesses" section: a bold accent panel on the left (tracked eyebrow,
// two-tone headline, two stats, and a CTA pill) beside a photo on the right.
// Highlights Quiver's migration from Mintlify to Blume. Stacks panel-over-photo
// on mobile, side-by-side from `lg`.

// Everything bespoke to this card lives up top so it's trivial to swap.
//
// The photo is a static asset: drop the file at `docs/public/quiver.jpg`
// (the `public/` dir is served at the site root, so it resolves to `/quiver.jpg`).
const photoSrc = "/quiver.jpg";
const photoAlt = "Quiver's documentation site, built with Blume";

// The customer's external link (per request, points at their docs).
const ctaHref = "https://docs.quiver.ai";
const ctaLabel = "Visit Quiver";

// Quiver's mark — fills its box and inherits the panel's foreground via
// `currentColor`, so it tracks the accent text colour.
const quiverLogo =
  '<svg class="size-full" viewBox="0 0 325 325" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M162.184 0C251.755 0.000255644 324.366 72.6125 324.366 162.184V324.366H162.184C72.6125 324.366 0.00025571 251.755 0 162.184C0 72.6123 72.6123 0 162.184 0ZM86.7959 77.1211C80.8505 75.1287 75.191 80.7986 77.1943 86.7402L143.065 282.081C145.811 290.223 157.844 288.249 157.844 279.656V157.267H279.43C288.03 157.266 289.995 145.217 281.84 142.484L86.7959 77.1211Z" fill="currentColor"/></svg>';

// Placeholder stats — swap each `value`/`label` for the real numbers from Quiver.
const stats = [
  { label: "command to migrate", value: "1" },
  { label: "of content preserved", value: "100%" },
];
---

<!-- Customer spotlight: Quiver's Mintlify → Blume migration as a split card. -->
<section>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-balance font-medium text-3xl tracking-tight sm:text-4xl">
      In good company.
    </h2>
    <p class="mt-4 text-balance text-muted-foreground">
      Docs teams are moving to Blume — bringing their whole site across in a
      single command.
    </p>
  </div>

  <div
    class="mx-auto mt-12 max-w-5xl overflow-hidden rounded-[2rem] border border-border bg-accent text-accent-foreground"
  >
    <div class="grid lg:grid-cols-2">
      <!-- Left: the accent panel. `isolate` scopes the faint dot grid behind the
           content; the panel's flex column pins stats + CTA to the bottom. -->
      <div
        class="relative isolate flex flex-col justify-between gap-12 p-8 sm:p-12"
      >
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 -z-10 opacity-[0.08]"
          style="background-image: radial-gradient(currentColor 1.25px, transparent 1.25px); background-size: 22px 22px;"
        >
        </div>

        <div>
          <span
            aria-label="Quiver"
            class="inline-flex size-8"
            role="img"
            set:html={quiverLogo}
          />
          <!-- Two-tone headline: base copy at 70% opacity, brand names at full
               strength — the rhythm Mintlify uses to make the key words pop. -->
          <h3
            class="mt-6 text-balance font-medium text-3xl text-accent-foreground/70 leading-tight tracking-tight sm:text-4xl"
          >
            See how <span class="text-accent-foreground">Quiver</span> migrated
            from Mintlify to <span class="text-accent-foreground">Blume</span>
          </h3>
        </div>

        <div>
          <dl class="flex flex-wrap gap-x-12 gap-y-6">
            {
              stats.map((stat) => (
                <div>
                  <dt class="font-medium text-4xl tracking-tight sm:text-5xl">
                    {stat.value}
                  </dt>
                  <dd class="mt-2 max-w-[9rem] text-accent-foreground/70 text-sm leading-snug">
                    {stat.label}
                  </dd>
                </div>
              ))
            }
          </dl>

          <a
            class="mt-8 inline-flex items-center gap-1.5 rounded-blume bg-background px-5 py-3 font-medium text-foreground text-sm transition-colors hover:bg-background/90"
            href={ctaHref}
            rel="noopener noreferrer"
            target="_blank"
          >
            {ctaLabel}
            <svg
              class="size-4"
              fill="none"
              height="16"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="16"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: the photo, filling its grid cell (which stretches to match the
           panel's height). `bg-muted` shows through until the asset is added. -->
      <div class="relative min-h-[280px] bg-muted lg:min-h-[440px]">
        <img
          alt={photoAlt}
          class="absolute inset-0 size-full object-cover"
          loading="lazy"
          src={photoSrc}
        />
      </div>
    </div>
  </div>
</section>
