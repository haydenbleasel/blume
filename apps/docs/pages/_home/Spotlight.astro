---
import { glyph } from "./shared.ts";

// Customer spotlight — full-bleed cards side by side, one per customer. Each
// card carries a dark backdrop (a decorative photo or a brand-tinted gradient)
// with a scrim over it, and the copy (logo, two-tone headline, and a CTA pill)
// pinned top-and-bottom on the left. Highlights QuiverAI's and Specific's
// migrations from Mintlify and Neon shipping their Postgres docs on Blume.

// QuiverAI's mark — fills its box and inherits the panel's foreground via
// `currentColor`, so it tracks the card's text colour.
const quiverLogo =
  '<svg class="size-full" viewBox="0 0 325 325" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M162.184 0C251.755 0.000255644 324.366 72.6125 324.366 162.184V324.366H162.184C72.6125 324.366 0.00025571 251.755 0 162.184C0 72.6123 72.6123 0 162.184 0ZM86.7959 77.1211C80.8505 75.1287 75.191 80.7986 77.1943 86.7402L143.065 282.081C145.811 290.223 157.844 288.249 157.844 279.656V157.267H279.43C288.03 157.266 289.995 145.217 281.84 142.484L86.7959 77.1211Z" fill="currentColor"/></svg>';

// Neon's "N" logomark, coloured with its brand green via `currentColor`.
const neonLogo =
  '<svg class="size-full" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill="currentColor" d="M27.542.008V28l-10.747-9.508v9.323H0V0zM3.376 24.439H13.42V11.084l10.747 9.508V3.382l-20.79-.005z"/></svg>';

// Specific's cube logomark, lifted from their full wordmark (which is too wide
// for the square logo slot) and recoloured via `currentColor`.
const specificLogo =
  '<svg class="size-full" viewBox="0 0 175 168" fill="none" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M174.887 67.075V133.825L116.549 167.245L0 100.079V33.4739L58.3469 0L174.887 67.075ZM119.487 95.3954L168.887 124.974V69.9832L119.487 41.6023V95.3954ZM61.2874 71.0658V125.709L113.537 95.6178L113.537 41.6369L61.2874 71.0658ZM4.5 96.3143L55.2874 125.331V70.6807L4.5 40.7412V96.3143Z" fill="currentColor"/></svg>';

// The featured cards. `headline` is a list of segments; `em` segments render
// at full strength (the brand names), the rest at 70% opacity — the two-tone
// rhythm Mintlify uses to make the key words pop. Each card paints a decorative
// `photo` (a static asset under `docs/public/`, served at the site root) behind
// its scrim, falling back to a plain black panel if one is ever omitted.
const cards = [
  {
    cta: { href: "https://docs.quiver.ai", label: "Visit QuiverAI" },
    headline: [
      { t: "See how " },
      { em: true, t: "QuiverAI" },
      { t: " migrated from Mintlify to " },
      { em: true, t: "Blume" },
    ],
    logo: quiverLogo,
    logoClass: "text-white",
    name: "QuiverAI",
    photo: "/quiver.jpg",
  },
  {
    cta: { href: "https://add-mcp.com/docs", label: "Visit add-mcp" },
    headline: [
      { t: "See how " },
      { em: true, t: "Neon" },
      { t: " ship their " },
      { em: true, t: "add-mcp" },
      { t: " docs on " },
      { em: true, t: "Blume" },
    ],
    logo: neonLogo,
    logoClass: "text-[#34d59a]",
    name: "Neon",
    photo: "/neon.jpg",
  },
  {
    cta: { href: "https://docs.specific.dev/", label: "Visit Specific" },
    headline: [
      { t: "See how " },
      { em: true, t: "Specific" },
      { t: " migrated from Mintlify to " },
      { em: true, t: "Blume" },
    ],
    logo: specificLogo,
    logoClass: "text-white",
    name: "Specific",
    photo: "/specific.jpg",
  },
];

// Customer wordmarks shown in a row beneath the card, each linking to that
// customer's site. Every path fills via `currentColor`, so the strip tracks the
// (theme-aware) foreground colour set on the row while the icons keep their
// internal `fill-opacity` layering. The link carries the accessible name; the
// SVG itself stays decorative.
