<!-- Customer spotlight: QuiverAI's, Neon's, and Specific's moves to Blume. -->
<section>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-balance font-medium text-3xl tracking-tight sm:text-4xl">
      You're in good company.
    </h2>
    <p class="mt-4 text-balance text-muted-foreground">
      Companies and open source libraries are moving their docs to Blume.
    </p>
  </div>

  <div class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-3">
    {
      cards.map((card) => (
        <div class="relative isolate flex min-h-[380px] flex-col justify-between gap-12 overflow-hidden rounded-[2rem] border border-border p-8 text-white sm:p-10">
          {/* Both photos are 1920×1080; declaring the intrinsic size lets the
              browser reserve the box (no layout shift on load) while CSS still
              stretches the image to fill the card. */}
          {card.photo ? (
            <img
              alt=""
              class="-z-20 absolute inset-0 size-full bg-muted object-cover"
              height={1080}
              loading="lazy"
              src={card.photo}
              width={1920}
            />
          ) : (
            <div aria-hidden="true" class="-z-20 absolute inset-0 bg-black" />
          )}
          {/* Dark scrim for legibility — heaviest on the left, where the copy
              sits, fading toward the right so more of the backdrop shows. */}
          <div
            aria-hidden="true"
            class="-z-10 absolute inset-0 bg-gradient-to-r from-black/85 via-black/55 to-black/20"
          />

          <div>
            <span
              aria-label={card.name}
              class:list={["inline-flex size-8", card.logoClass]}
              role="img"
              set:html={card.logo}
            />
            {/* Two-tone headline: base copy at 70% opacity, brand names at full
                strength — the rhythm Mintlify uses to make the key words pop. */}
            <h3 class="mt-6 text-balance font-medium text-2xl text-white/70 leading-tight tracking-tight">
              {card.headline.map((seg) =>
                seg.em ? <span class="text-white">{seg.t}</span> : seg.t
              )}
            </h3>
          </div>

          <a
            class="inline-flex items-center gap-1.5 self-start rounded-blume bg-white/10 px-5 py-3 font-medium text-sm text-white transition-colors hover:bg-white hover:text-black"
            href={card.cta.href}
            rel="noopener noreferrer"
            target="_blank"
          >
            {card.cta.label}
            <svg
              class="size-4"
              fill="none"
              height="16"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              viewBox="0 0 24 24"
              width="16"
              set:html={glyph("chevron-right")}
            />
          </a>
        </div>
      ))
    }
  </div>

  <!-- Customer wordmarks, in a single row beneath the card. -->
  <ul
    class="mx-auto mt-10 flex max-w-4xl flex-wrap items-center justify-center gap-x-8 gap-y-6 text-muted-foreground sm:mt-12 sm:gap-x-10"
    role="list"
  >
    {
      customerLogos.map((logo) => (
        <li class="flex items-center">
          <a
            aria-label={logo.name}
            class="text-muted-foreground transition-colors hover:text-foreground"
            href={logo.href}
            rel="noopener noreferrer"
            set:html={logo.svg}
            target="_blank"
          />
        </li>
      ))
    }
  </ul>
</section>
