---

<!-- Customer spotlight: Quiver's Mintlify → Blume migration as a split card. -->
<section>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-balance font-medium text-3xl tracking-tight sm:text-4xl">
      You're in good company.
    </h2>
    <p class="mt-4 text-balance text-muted-foreground">
      Companies and open source libraries are moving their docs to Blume.
    </p>
  </div>

  <div
    class="relative isolate mx-auto mt-12 max-w-5xl overflow-hidden rounded-[2rem] border border-border text-white"
  >
    <!-- Full-bleed decorative backdrop covering the whole card. `bg-muted` shows
         through until the asset is added. -->
    <img
      alt=""
      class="-z-20 absolute inset-0 size-full bg-muted object-cover"
      loading="lazy"
      src={photoSrc}
    />
    <!-- Dark scrim for legibility — heaviest on the left, where the copy sits,
         fading toward the right so more of the photo shows through. -->
    <div
      aria-hidden="true"
      class="-z-10 absolute inset-0 bg-gradient-to-r from-black/85 via-black/55 to-black/10"
    >
    </div>

    <!-- Copy, pinned to the top (logo + headline) and bottom (stats + CTA). -->
    <div
      class="flex min-h-[440px] max-w-xl flex-col justify-between gap-12 p-8 sm:p-12"
    >
      <div>
        <span
          aria-label="Quiver"
          class="inline-flex size-8"
          role="img"
          set:html={quiverLogo}
        />
        <!-- Two-tone headline: base copy at 70% opacity, brand names at full
             strength — the rhythm Mintlify uses to make the key words pop. -->
        <h3
          class="mt-6 text-balance font-medium text-3xl text-white/70 leading-tight tracking-tight sm:text-4xl"
        >
          See how <span class="text-white">Quiver</span> migrated from Mintlify
          to <span class="text-white">Blume</span>
        </h3>
      </div>

      <div>
        <a
          class="mt-8 inline-flex items-center gap-1.5 rounded-blume bg-white/10 px-5 py-3 font-medium text-white text-sm transition-colors hover:bg-white hover:text-black"
          href={ctaHref}
          rel="noopener noreferrer"
          target="_blank"
        >
          {ctaLabel}
          <svg
            class="size-4"
            fill="none"
            height="16"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            viewBox="0 0 24 24"
            width="16"
            set:html={glyph("chevron-right")}
          />
        </a>
      </div>
    </div>

    <!-- Docs-site screenshot on the right, sized larger than the card and
         anchored to the top-left so it reads as a zoomed crop of a bigger
         graphic: it overflows the card's right and bottom edges (clipped by
         `overflow-hidden`), leaving its rounded top-left corner in view. Hidden
         on small screens, where the copy takes the whole card width. -->
    <div class="pointer-events-none absolute top-8 left-1/2 hidden lg:block">
      <img
        alt={docsAlt}
        class="w-[52rem] max-w-none rounded-xl border border-white/15 shadow-2xl shadow-black/40"
        loading="lazy"
        src={docsSrc}
      />
    </div>
  </div>

  <!-- Customer wordmarks, in a single row beneath the card. -->
  <ul
    class="mx-auto mt-10 flex max-w-4xl flex-wrap items-center justify-center gap-x-10 gap-y-6 text-muted-foreground sm:mt-12 sm:gap-x-16"
    role="list"
  >
    {
      customerLogos.map((logo) => (
        <li class="flex items-center">
          <a
            aria-label={logo.name}
            class="text-muted-foreground transition-colors hover:text-foreground"
            href={logo.href}
            rel="noopener noreferrer"
            set:html={logo.svg}
            target="_blank"
          />
        </li>
      ))
    }
  </ul>
</section>
