---
// "Batteries included" — a column of feature blocks paired with a single
// browser-window graphic that stays centred in the viewport and crossfades its
// contents as you scroll. `kind` selects which mock <FeatureBrowser> renders.
import FeatureBrowser from "../_FeatureBrowser.astro";
import { icons } from "./shared.ts";

const features = [
  {
    body: "A folder of Markdown is a complete project — there's no starter to clone and no template to keep in sync with upstream.",
    checklist: [
      "Navigation is inferred from your files",
      "Search, theming, and OG images are on by default",
      "Reach for configuration only when you need it",
    ],
    icon: icons.config,
    kind: "page",
    title: "Zero-config, even the template",
  },
  {
    body: "Drop in an OpenAPI or AsyncAPI spec and Blume renders a full interactive reference — endpoints, schemas, and a live playground.",
    checklist: [
      "OpenAPI and AsyncAPI specs",
      "Interactive “Try it” playground",
      "Powered by Scalar, themed to match",
    ],
    icon: icons.api,
    kind: "api",
    title: "Interactive API references",
  },
  {
    body: "30+ accessible components and a curated set of Markdown extensions, usable in any .mdx page with nothing to import.",
    checklist: [
      "Callouts, cards, steps, tabs, and file trees",
      "Package-install tabs and code groups",
      "Mermaid diagrams and KaTeX math",
    ],
    icon: icons.components,
    kind: "components",
    title: "Components, included",
  },
  {
    body: "Search, SEO, and internationalization that scale from a personal project to a site with thousands of pages.",
    checklist: [
      "Local search in dev and production",
      "OG images, sitemaps, RSS, and JSON-LD",
      "36 locales with full right-to-left support",
    ],
    icon: icons.search,
    kind: "search",
    title: "Production-ready by default",
  },
];

// Tracks whichever feature block is nearest the viewport centre: dims the others
// and crossfades the sticky browser graphic to that feature's panel. A rAF-
// throttled scroll handler (rather than IntersectionObserver) keeps it reliable;
// with no JS every block stays legible and the first panel shows.
const featuresScript = `(()=>{const r=document.querySelector("[data-blume-features]");if(!r)return;const items=[...r.querySelectorAll("[data-feature]")];if(!items.length)return;const panels=[...r.querySelectorAll("[data-panel]")];let raf=0,cur=-1;const update=()=>{raf=0;const mid=innerHeight/2;let best=0,bd=Infinity;items.forEach((it,j)=>{const b=it.getBoundingClientRect();const d=Math.abs(b.top+b.height/2-mid);if(d<bd){bd=d;best=j;}});if(best===cur)return;cur=best;items.forEach((it,j)=>{it.dataset.active=String(j===best);});panels.forEach((p,j)=>{p.dataset.active=String(j===best);});};const onScroll=()=>{if(!raf)raf=requestAnimationFrame(update);};addEventListener("scroll",onScroll,{passive:true});addEventListener("resize",onScroll,{passive:true});update();})();`;
---

<!-- Batteries included: one sticky browser window whose contents morph per feature (x.ai/cli-style) -->
<section data-blume-features>
  <div class="max-w-2xl">
    <h2 class="font-medium text-3xl tracking-tight sm:text-4xl">
      Batteries included.
    </h2>
    <p class="mt-4 text-muted-foreground">
      Everything a production docs site needs — zero-config setup, AI, a component
      library, search, SEO, and i18n — without a plugin to install or a service to
      wire up.
    </p>
  </div>

  <div class="mt-8 lg:grid lg:grid-cols-[5fr_7fr] lg:gap-x-10">
    <!-- Feature blocks. The column is padded top and bottom so the sticky
         graphic (range = column height − 100vh) stays centred through the
         first and last features instead of easing in/out over them. -->
    <div class="lg:py-[15vh]">
      {
        features.map((feature, index) => (
          <article
            class="transition-opacity duration-500 lg:flex lg:min-h-[72vh] lg:flex-col lg:justify-center lg:data-[active=false]:opacity-40"
            data-feature={index}
          >
            <div class="pt-10 lg:pt-0">
              <span class="inline-flex size-10 items-center justify-center rounded-blume bg-muted text-accent">
                <svg
                  class="size-5"
                  fill="none"
                  height="20"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="20"
                  set:html={feature.icon}
                />
              </span>
              <h3 class="mt-5 font-medium text-foreground text-xl tracking-tight sm:text-2xl">
                {feature.title}
              </h3>
              <p class="mt-3 max-w-md text-muted-foreground leading-relaxed">
                {feature.body}
              </p>
              <ul class="mt-6 space-y-3">
                {feature.checklist.map((item) => (
                  <li class="flex items-start gap-2.5 text-foreground text-sm">
                    <svg
                      class="mt-0.5 size-4 shrink-0 text-accent"
                      fill="none"
                      height="16"
                      stroke="currentColor"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                      width="16"
                      set:html={icons.check}
                    />
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
            {/* Inline browser graphic for mobile; desktop uses the shared sticky one. */}
            <div class="pt-6 pb-10 lg:hidden">
              <div class="overflow-hidden rounded-blume border border-border bg-background shadow-xl shadow-foreground/[0.06]">
                <FeatureBrowser kind={feature.kind} />
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- One sticky browser window; the active feature's panel crossfades in.
         A full-height (h-screen) sticky wrapper pinned at the top keeps the
         window centred in the viewport for the whole section — no transform
         overshoot, no per-feature offset math. -->
    <div class="hidden lg:block">
      <div class="sticky top-0 flex h-screen flex-col justify-center">
        <div class="relative h-[460px] overflow-hidden rounded-blume border border-border bg-background shadow-2xl shadow-foreground/10">
          {
            features.map((feature, index) => (
              <div
                class="absolute inset-0 opacity-0 transition-opacity duration-500 data-[active=true]:opacity-100"
                data-active={index === 0 ? "true" : "false"}
                data-panel={index}
              >
                <FeatureBrowser kind={feature.kind} />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline set:html={featuresScript} />
