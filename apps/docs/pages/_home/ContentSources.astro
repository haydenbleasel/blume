const sources = [
  { logo: markdownLogo, title: "Markdown" },
  { logo: mdxLogo, title: "MDX" },
  { logo: notionLogo, title: "Notion" },
  { logo: sanityLogo, title: "Sanity" },
];

// Rendered through an Astro expression so the object/array syntax auto-escapes.
const configSource = `import { defineConfig } from "blume";

export default defineConfig({
  content: {
    sources: [
      { type: "filesystem", root: "docs" },
      { type: "mdx-remote", github: { owner: "comet", repo: "docs", path: "docs" } },
      { type: "sanity", projectId: "p1", dataset: "production", query: "*[_type == 'doc']" },
      { type: "notion", database: process.env.NOTION_DB },
    ],
  },
});`;
---

<!-- Content from anywhere -->
<section>
  <div class="mx-auto max-w-2xl text-center">
    <!-- Overlapping source marks. Leftmost sits on top (descending z-index). -->
    <div class="flex justify-center -space-x-4">
      {
        sources.map((source, index) => (
          <span
            class="relative inline-flex size-16 items-center justify-center overflow-hidden rounded-full border border-border [&>svg]:size-full"
            set:html={source.logo}
            style={`z-index:${sources.length - index}`}
            title={source.title}
          />
        ))
      }
    </div>

    <h2 class="mt-8 text-balance font-medium text-3xl tracking-tight sm:text-4xl">
      Content from anywhere.
    </h2>
    <p class="mt-4 text-balance text-muted-foreground">
      Blume reads a folder of Markdown by default — but content can just as
      easily come from a remote repo, a CMS, or any custom backend. Mix several
      sources into a single site; they all render through the same components.
    </p>
  </div>

  <!-- One config, every source. Shiki highlights at build time; the
       `blume-config-mockup` class scopes the dark/light var switch below. -->
  <div
    class="blume-config-mockup mx-auto mt-12 max-w-3xl overflow-hidden rounded-blume border border-border bg-background"
  >
    <div
      class="flex items-center gap-2 border-border border-b bg-muted/40 px-4 py-2.5 text-[11px] text-muted-foreground"
    >
      <svg
        class="size-3.5"
        fill="none"
        height="14"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="14"
        set:html={icons.config}
      ></svg>
      <span class="font-mono">blume.config.ts</span>
    </div>
    <Code
      code={configSource}
      defaultColor={false}
      lang="ts"
      themes={{ dark: "github-dark", light: "github-light" }}
    />
  </div>

  <p class="mx-auto mt-6 max-w-xl text-balance text-center text-muted-foreground text-sm">
    Need another backend? A <code class="font-mono text-foreground text-[13px]">custom</code> source
    adapter ships any CMS without its SDK touching core.
    {" "}
    <a class="font-medium text-foreground underline-offset-4 hover:underline" href="/docs/content/sources">
      Learn about content sources
    </a>.
  </p>
</section>

<!--
  Shiki runs with `defaultColor: false`, so it only emits `--shiki-light` /
  `--shiki-dark` CSS vars (no committed colors). The package switches them in
  `theme/entry.ts`, but only under `.prose` — which the homepage isn't. This
  mirrors that switch, scoped to the mockup, and gives the generated `pre` the
  padding/font the static block used to carry.
-->
<style is:global>
  .blume-config-mockup .astro-code {
    margin: 0;
    overflow-x: auto;
    padding: 1.25rem;
    background: transparent !important;
    font-family: var(--blume-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.75rem;
    line-height: 1.625;
  }

  @media (min-width: 640px) {
    .blume-config-mockup .astro-code {
      font-size: 13px;
    }
  }

  .blume-config-mockup .astro-code,
  .blume-config-mockup .astro-code span {
    color: var(--shiki-light, var(--blume-foreground));
  }

  .blume-config-mockup .astro-code span {
    font-style: var(--shiki-light-font-style, inherit);
    font-weight: var(--shiki-light-font-weight, inherit);
  }

  :root[data-theme="dark"] .blume-config-mockup .astro-code,
  :root[data-theme="dark"] .blume-config-mockup .astro-code span {
    color: var(--shiki-dark, var(--blume-foreground));
  }

  :root[data-theme="dark"] .blume-config-mockup .astro-code span {
    font-style: var(--shiki-dark-font-style, inherit);
    font-weight: var(--shiki-dark-font-weight, inherit);
  }
</style>
