---
// "Content from anywhere." — Blume reads local Markdown by default, but content
// can also come from a remote repo, a CMS (Sanity, Notion), or any custom
// adapter. A stack of overlapping source marks sits above the heading; the
// config snippet below shows the matching `content.sources` entries.
import { Code } from "astro:components";
import { icons } from "./shared.ts";

