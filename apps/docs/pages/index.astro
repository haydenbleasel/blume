---
import PageLayout from "blume/components/layout/PageLayout.astro";
import data from "blume:data";
import Batteries from "./_home/Batteries.astro";
import BuiltForModels from "./_home/BuiltForModels.astro";
import Components from "./_home/Components.astro";
import ContentSources from "./_home/ContentSources.astro";
import Footer from "./_home/Footer.astro";
import Hero from "./_home/Hero.astro";
import InstallCta from "./_home/InstallCta.astro";
import MarkdownShowcase from "./_home/MarkdownShowcase.astro";
import ProductPreview from "./_home/ProductPreview.astro";
import { installCopyScript } from "./_home/shared.ts";
import Spotlight from "./_home/Spotlight.astro";

// Everything the landing page needs comes from the resolved Blume config, so it
// stays in sync with the docs site (title, description, banner, theme mode).
// PageLayout supplies the document shell, header, theme, and fonts — the
// document `<html>`/`<head>`, theme + banner pre-paint scripts, and banner that
// this page used to hand-roll all live there now.
const { config } = data;
const pageTitle = `${config.title} — fast, AI-ready, markdown-first docs`;
// A landing-page-specific meta description so the home page reads distinctly
// from the site-wide default (which other pages fall back to).
const pageDescription =
  "Ship beautiful, fast, AI-ready documentation from plain markdown. Blume gives you search, theming, SEO, and one-command deploys on Astro and Vite.";
---

<PageLayout
  analytics={config.analytics}
  banner={config.banner}
  favicon={config.favicon}
  fontCssVars={data.fontCssVars}
  logo={config.logo}
  navigation={data.navigation}
  ogEnabled={config.og.enabled}
  ogImage="/opengraph-image.png"
  page={{ description: pageDescription, route: "/", title: pageTitle }}
  searchEnabled={config.search.enabled}
  site={{ description: config.description, title: config.title }}
  siteUrl={config.site}
  themeMode={config.theme.mode}
  x={config.x}
>
  <div
    class="mx-auto grid max-w-[1400px] gap-16 px-6 py-20 sm:py-24 lg:gap-24 xl:gap-32"
  >
    <Hero />

    <ProductPreview />

    <Batteries />

    <MarkdownShowcase />

    <ContentSources />

    <BuiltForModels />

    <Spotlight />

    <Components />

    <InstallCta />
  </div>
  <script is:inline set:html={installCopyScript} />
  <Footer slot="footer" />
</PageLayout>
