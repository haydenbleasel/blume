---
// A theme-aware browser window used by the homepage "Batteries included"
// section. The same component renders in the sticky desktop graphic (crossfaded
// per feature) and inline on mobile, so each `kind` lives in exactly one place.
// It mirrors the hero product preview: app header + a three-pane docs layout
// (sidebar · content · on-this-page). Only the content morphs. It depicts the
// fictional "Comet" brand (see `sampleBrand` in _home/shared.ts).
import { sampleBrand } from "./_home/shared.ts";

interface Props {
  kind: string;
}
const { kind } = Astro.props;

const sparkle =
  '<path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3z"/>';
const searchIcon = '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>';
const rocket =
  '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>';
const sliders =
  '<line x1="4" x2="4" y1="21" y2="14"/><line x1="4" x2="4" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="12"/><line x1="12" x2="12" y1="8" y2="3"/><line x1="20" x2="20" y1="21" y2="16"/><line x1="20" x2="20" y1="12" y2="3"/><line x1="2" x2="6" y1="14" y2="14"/><line x1="10" x2="14" y1="8" y2="8"/><line x1="18" x2="22" y1="16" y2="16"/>';
const fileText =
  '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 13H8"/><path d="M16 17H8"/>';

// The docs sidebar groups; the active item and right-rail outline change per
// feature. The `api` kind swaps this sidebar for OpenAPI endpoints (see below).
const navGroups = sampleBrand.sidebar;
const meta = {
  api: {
    active: "Messages",
    crumb: "API reference",
    heading: "Get a message",
    toc: ["Parameters", "Responses", "Schema"],
  },
  components: {
    active: "Quickstart",
    crumb: "Get started",
    heading: "Quickstart",
    toc: ["Install the SDK", "Send a message", "Next steps"],
  },
  page: {
    active: "Introduction",
    crumb: "Get started",
    heading: "Introduction",
    toc: ["Why Comet", "What's included", "Next steps"],
  },
  // The search kind opens a ⌘K modal over a normal docs page, so its "view"
  // mirrors the Introduction page that sits (dimmed) behind the overlay.
  search: {
    active: "Introduction",
    crumb: "Get started",
    heading: "Introduction",
    toc: ["Why Comet", "What's included", "Next steps"],
  },
};
const view = meta[kind as keyof typeof meta] ?? meta.page;

// The "Popular" results in the search-palette mock (titles only, like the real
// ⌘K menu); the first row renders as the highlighted/active result.
const searchResults = ["Quickstart", "Messages", "Templates", "Webhooks"];

// For the `api` kind the sidebar swaps to OpenAPI endpoints (Scalar-style):
// the operation summary on the left, a colour-coded method badge on the right.
const apiGroups = sampleBrand.api;
const apiEndpoint = "/messages/{id}";
const methodColor: Record<string, string> = {
  DELETE: "text-[#ef4444]",
  GET: "text-[#3b82f6]",
  POST: "text-[#16a34a]",
  PUT: "text-[#f59e0b]",
};
const methodLabel: Record<string, string> = { DELETE: "DEL" };
const apiResponse = `{
  "id": "msg_01H8...",
  "to": "ada@example.com",
  "status": "delivered"
}`;
---

<div class="relative flex h-full flex-col">
  {/* App header */}
  <div
    class="flex items-center justify-between border-border border-b px-4 py-2.5"
  >
    <div class="flex items-center gap-4">
      <span class="flex items-center gap-1.5 font-medium text-foreground text-sm">
        <span
          aria-hidden="true"
          class="inline-flex h-4 items-center text-accent [&>svg]:h-4 [&>svg]:w-auto"
          set:html={sampleBrand.logo}
        />
        {sampleBrand.name}
      </span>
      <nav class="hidden items-center gap-3 text-[11px] text-muted-foreground sm:flex">
        <span class={kind === "api" ? "" : "text-foreground"}>Docs</span>
        <span class={kind === "api" ? "text-foreground" : ""}>API</span>
        <span>Changelog</span>
      </nav>
    </div>
    <span
      class="hidden items-center gap-2 rounded-full border border-border px-3 py-1 text-[11px] text-muted-foreground sm:flex"
    >
      <svg
        class="size-3"
        fill="none"
        height="12"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="12"
        set:html={searchIcon}
      />
      Search
      <span class="ml-2 rounded border border-border px-1 font-mono">⌘K</span>
    </span>
  </div>

  {/* Three-pane docs body */}
  <div
    class="grid min-h-[332px] flex-1 grid-cols-1 sm:grid-cols-[148px_1fr] lg:grid-cols-[148px_1fr_140px]"
  >
    {/* Sidebar */}
    <aside class="hidden border-border border-r p-4 text-[11px] sm:block">
      {
        kind === "api" ? (
          apiGroups.map((group) => (
            <div class="mb-4 last:mb-0">
              <p class="font-medium text-foreground">{group.label}</p>
              <ul class="mt-2 space-y-0.5">
                {group.items.map((ep) => (
                  <li
                    class={`flex items-center gap-2 rounded px-1.5 py-1 ${ep.method === "GET" && ep.path === "/messages/{id}" ? "bg-muted text-foreground" : "text-muted-foreground"}`}
                  >
                    <span class="flex-1 truncate">{ep.summary}</span>
                    <span
                      class={`shrink-0 font-mono font-semibold text-[9px] ${methodColor[ep.method]}`}
                    >
                      {methodLabel[ep.method] ?? ep.method}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        ) : (
          navGroups.map((group) => (
            <div class="mb-4 last:mb-0">
              <p class="font-medium text-foreground">{group.label}</p>
              <ul class="mt-2 space-y-1.5 text-muted-foreground">
                {group.items.map((item) => (
                  <li class={item === view.active ? "text-accent" : ""}>{item}</li>
                ))}
              </ul>
            </div>
          ))
        )
      }
    </aside>

    {/* Content (morphs per feature) */}
    <div class="min-w-0 p-5">
      <p class="text-[11px] text-muted-foreground">{view.crumb}</p>
      <h4 class="mt-1 font-semibold text-foreground text-xl tracking-tight">
        {view.heading}
      </h4>

      {
        (kind === "page" || kind === "search") && (
          <div>
            <p class="mt-2 text-muted-foreground text-xs leading-relaxed">
              Comet is a transactional email & SMS API. Send your first message in
              minutes, then add templates, webhooks, and analytics as you grow.
            </p>
            <div class="mt-4 grid grid-cols-2 gap-3">
              <div class="rounded-blume border border-border p-3">
                <svg
                  class="size-4 text-accent"
                  fill="none"
                  height="16"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="16"
                  set:html={rocket}
                />
                <p class="mt-2 font-medium text-foreground text-xs">Quickstart</p>
                <p class="mt-0.5 text-[11px] text-muted-foreground">
                  Send your first message
                </p>
              </div>
              <div class="rounded-blume border border-border p-3">
                <svg
                  class="size-4 text-accent"
                  fill="none"
                  height="16"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  width="16"
                  set:html={sliders}
                />
                <p class="mt-2 font-medium text-foreground text-xs">
                  Authentication
                </p>
                <p class="mt-0.5 text-[11px] text-muted-foreground">
                  API keys & scopes
                </p>
              </div>
            </div>
            <div class="mt-3 flex gap-2 rounded-blume border-accent border-l-2 bg-accent/5 p-3">
              <svg
                class="mt-px size-3.5 shrink-0 text-accent"
                fill="none"
                height="14"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="14"
                set:html={sparkle}
              />
              <p class="text-[11px] text-foreground leading-relaxed">
                <span class="font-medium">Tip</span> — every request is
                idempotent; safely retry without sending twice.
              </p>
            </div>
          </div>
        )
      }

      {
        kind === "api" && (
          <div>
            <div class="mt-2 flex items-center gap-2">
              <span class="font-mono font-semibold text-[11px] text-[#3b82f6]">
                GET
              </span>
              <span class="font-mono text-[11px] text-muted-foreground">
                {apiEndpoint}
              </span>
            </div>
            <p class="mt-3 text-muted-foreground text-xs leading-relaxed">
              Returns a single message by its ID — rendered straight from your
              OpenAPI spec, with a live “Try it” playground.
            </p>
            <p class="mt-4 border-border border-b pb-2 font-medium text-[11px] text-foreground">
              Path Parameters
            </p>
            <div class="mt-2 text-[11px]">
              <span class="font-mono font-semibold text-foreground">id</span>
              <span class="ml-2 text-muted-foreground">string</span>
              <span class="ml-2 text-[10px] text-[#f59e0b]">required</span>
              <p class="mt-0.5 text-[10px] text-muted-foreground">
                The ID of the message to return.
              </p>
            </div>
            <p class="mt-4 border-border border-b pb-2 font-medium text-[11px] text-foreground">
              Responses
            </p>
            <div class="mt-2 overflow-hidden rounded-blume border border-border">
              <div class="flex items-center gap-2 border-border border-b bg-muted/40 px-3 py-1.5 text-[10px]">
                <span class="font-mono font-semibold text-[#16a34a]">200</span>
                <span class="text-muted-foreground">successful operation</span>
              </div>
              <pre class="overflow-x-auto px-3 py-2 font-mono text-[10px] text-muted-foreground"><code>{apiResponse}</code></pre>
            </div>
          </div>
        )
      }

      {
        kind === "components" && (
          <div class="space-y-3">
            <p class="mt-2 text-muted-foreground text-xs leading-relaxed">
              Comet's docs use 30+ accessible components — callouts, cards, steps,
              and tabs — with nothing to import.
            </p>
            <div class="flex gap-2 rounded-blume border-accent border-l-2 bg-accent/5 p-3">
              <svg
                class="mt-px size-3.5 shrink-0 text-accent"
                fill="none"
                height="14"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="14"
                set:html={sparkle}
              />
              <p class="text-[11px] text-foreground leading-relaxed">
                <span class="font-medium">Tip</span> — every component is
                React-free and theme-aware.
              </p>
            </div>
            <div class="grid grid-cols-2 gap-2">
              <div class="rounded-blume border border-border p-3">
                <span class="font-medium text-foreground text-xs">Card</span>
                <p class="mt-0.5 text-[10px] text-muted-foreground">
                  Linked preview
                </p>
              </div>
              <div class="rounded-blume border border-border p-3">
                <span class="font-medium text-foreground text-xs">Steps</span>
                <p class="mt-0.5 text-[10px] text-muted-foreground">
                  Ordered guide
                </p>
              </div>
            </div>
            <div class="overflow-hidden rounded-blume border border-border">
              <div class="flex items-center justify-between border-border border-b bg-muted/40 px-3 py-1.5 text-[10px] text-muted-foreground">
                <span class="font-mono">quickstart.mdx</span>
              </div>
              <pre class="overflow-x-auto px-3 py-2 font-mono text-[10px] text-muted-foreground"><code>&lt;Tabs&gt; · &lt;Accordion&gt; · &lt;FileTree&gt;</code></pre>
            </div>
          </div>
        )
      }

    </div>

    {/* On this page */}
    <aside class="hidden border-border border-l p-4 text-[11px] lg:block">
      <p class="font-medium text-foreground">On this page</p>
      <ul class="mt-2 space-y-1.5 text-muted-foreground">
        {
          view.toc.map((item, index) => (
            <li class={index === 0 ? "text-foreground" : ""}>{item}</li>
          ))
        }
      </ul>
    </aside>

    {/* Search: a ⌘K command palette modal over the dimmed page. The backdrop is
        positioned to the window root, so it covers the whole window — nav
        included — like the real ⌘K overlay. */}
    {
      kind === "search" && (
        <div class="absolute inset-0 z-10 flex items-start justify-center bg-foreground/20 p-6 pt-20 backdrop-blur-[2px]">
          <div class="w-full max-w-md overflow-hidden rounded-blume border border-border bg-background shadow-2xl shadow-foreground/20">
            <div class="flex items-center gap-2 border-border border-b px-3 py-2.5">
              <svg
                class="size-3.5 text-muted-foreground"
                fill="none"
                height="14"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                viewBox="0 0 24 24"
                width="14"
                set:html={searchIcon}
              />
              <span class="flex-1 text-muted-foreground text-xs">
                Search documentation…
              </span>
              <span class="rounded border border-border px-1.5 py-0.5 text-[10px] text-muted-foreground">
                Esc
              </span>
            </div>
            <div class="p-2">
              <p class="px-2 pt-1 pb-1.5 text-[10px] text-muted-foreground">
                Popular
              </p>
              {searchResults.map((result, index) => (
                <div
                  class={`flex items-center gap-2.5 rounded-blume px-2 py-1.5 ${index === 0 ? "border border-border bg-muted" : ""}`}
                >
                  <svg
                    class="size-3.5 shrink-0 text-muted-foreground"
                    fill="none"
                    height="14"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                    width="14"
                    set:html={fileText}
                  />
                  <span class="text-foreground text-xs">{result}</span>
                </div>
              ))}
            </div>
            <div class="flex items-center gap-3 border-border border-t px-3 py-1.5 text-[10px] text-muted-foreground">
              <span>↑↓ navigate</span>
              <span>↵ open</span>
              <span class="ml-auto">⌘] preview</span>
            </div>
          </div>
        </div>
      )
    }
  </div>
</div>
